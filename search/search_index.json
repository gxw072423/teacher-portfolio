1f\u89c9\u5f97\"\u539f\u6765\u5982\u6b64\"\u3002</p> <p>\u6211\u7406\u89e3\u7684\u7f16\u7a0b\u6559\u5b66\u6709\u4e09\u4e2a\u5c42\u6b21\uff1a</p> <ol> <li>\u4f1a\u7528 \u2014 \u80fd\u5199\u51fa\u80fd\u8dd1\u7684\u4ee3\u7801\uff0c\u89e3\u51b3\u57fa\u672c\u95ee\u9898</li> <li>\u4f1a\u60f3 \u2014 \u7406\u89e3\u5e95\u5c42\u539f\u7406\uff0c\u80fd\u81ea\u5df1\u5206\u6790\u95ee\u9898\u3001\u8bbe\u8ba1\u65b9\u6848</li> <li>\u4f1a\u6559 \u2014 \u80fd\u628a\u4f60\u61c2\u7684\u4e1c\u897f\uff0c\u7528\u522b\u4eba\u80fd\u7406\u89e3\u7684\u65b9\u5f0f\u8bb2\u6e05\u695a</li> </ol> <p>\u6211\u89c9\u5f97\u5927\u90e8\u5206\u8bfe\u7a0b\u53ea\u6559\u5230\u7b2c\u4e00\u5c42\uff0c\u597d\u4e00\u70b9\u7684\u6559\u5230\u7b2c\u4e8c\u5c42\u3002\u800c\u6211\u60f3\u505a\u7684\uff0c\u662f\u628a\u8fd9\u4e09\u5c42\u90fd\u6253\u901a\u2014\u2014\u7528\u8bbe\u8ba1\u7684\u53ef\u89c6\u5316\u80fd\u529b\u964d\u4f4e\u95e8\u69db\uff0c\u7528\u5bb6\u6559\u7684\u8010\u5fc3\u5f15\u5bfc\u601d\u8003\uff0c\u7528 AI \u5de5\u5177\u63d0\u5347\u6548\u7387\u3002</p> <p>\u5728 AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4e0d\u5e94\u8be5\u548c\u5b66\u751f\u62a2\u996d\u7897\uff08\"\u4f60\u770b\u6211\u4e5f\u4f1a\u5199\u4ee3\u7801\"\uff09\uff0c\u800c\u5e94\u8be5\u6559\u90a3\u4e9b AI \u66ff\u4ee3\u4e0d\u4e86\u7684\u4e1c\u897f\uff1a\u8ba1\u7b97\u601d\u7ef4\u3001\u95ee\u9898\u62c6\u89e3\u3001\u5224\u65ad\u597d\u574f\u4ee3\u7801\u7684\u80fd\u529b\u3001\u548c AI \u9ad8\u6548\u534f\u4f5c\u7684\u65b9\u6cd5\u3002</p>"},{"location":"about/#_9","title":"\u8054\u7cfb\u6211","text":"<ul> <li>\ud83d\udce7 gxw072423@163.com</li> <li>\ud83d\udc19 github.com/gxw072423</li> </ul>"},{"location":"blog/","title":"\u6280\u672f\u6587\u7ae0","text":"<p>\u4e00\u4e9b\u6211\u5728\u5b66\u4e60\u548c\u6559\u5b66\u8fc7\u7a0b\u4e2d\u5199\u7684\u7b14\u8bb0\u3002\u4e0d\u7b97\u6df1\u5ea6\u597d\u6587\uff0c\u4f46\u90fd\u662f\u771f\u5b9e\u7684\u601d\u8003\u548c\u603b\u7ed3\u3002</p>"},{"location":"blog/#_2","title":"\u6587\u7ae0\u5217\u8868","text":"<p>\u9605\u8bfb \u2192</p> <p>\u9605\u8bfb \u2192</p> <p>\u9605\u8bfb \u2192</p> <p>\u9605\u8bfb \u2192</p>"},{"location":"blog/#5","title":"\u7f16\u7a0b\u521d\u5b66\u8005\u6700\u5bb9\u6613\u72af\u7684 5 \u4e2a\u9519\u8bef","text":"<p>2025-07\u6559\u5b66\u5fc3\u5f97</p> <p>\u4ece\u505a\u5bb6\u6559\u7684\u7ecf\u5386\u51fa\u53d1\uff0c\u804a\u804a\u65b0\u624b\u5b66\u7f16\u7a0b\u65f6\u4f1a\u6389\u8fdb\u53bb\u7684\u5751\u3002</p>"},{"location":"blog/#figma","title":"\u4ece Figma \u5230\u4ee3\u7801\uff1a\u8bbe\u8ba1\u5e08\u5b66\u524d\u7aef\u600e\u4e48\u5165\u95e8","text":"<p>2025-06\u8bbe\u8ba1+\u5f00\u53d1</p> <p>\u7528\u8bbe\u8ba1\u601d\u7ef4\u964d\u4f4e\u524d\u7aef\u5b66\u4e60\u95e8\u69db\u2014\u2014\u6211\u81ea\u5df1\u5c31\u662f\u8fd9\u4e48\u8d70\u8fc7\u6765\u7684\u3002</p>"},{"location":"blog/#ai","title":"AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4f1a\u88ab\u6dd8\u6c70\u5417\uff1f","text":"<p>2025-07\u884c\u4e1a\u601d\u8003</p> <p>\u6211\u81ea\u5df1\u7684\u56de\u7b54\u662f\uff1a\u4e0d\u4f1a\uff0c\u4f46\u5de5\u4f5c\u7684\u5185\u5bb9\u4f1a\u53d8\u3002</p>"},{"location":"blog/#vue","title":"Vue \u54cd\u5e94\u5f0f\u539f\u7406\u2014\u2014\u8bd5\u7740\u7528\u4eba\u8bdd\u8bb2\u6e05\u695a","text":"<p>2025-05\u524d\u7aef\u539f\u7406</p> <p>\u4e0d\u7528\u672f\u8bed\uff0c\u7528\u5916\u5356\u8ba2\u5355\u7684\u4f8b\u5b50\u89e3\u91ca Vue \u7684\u54cd\u5e94\u5f0f\u662f\u600e\u4e48\u4e00\u56de\u4e8b\u3002</p>"},{"location":"blog/#_3","title":"\u6587\u7ae0\u6b63\u6587","text":""},{"location":"blog/#a1","title":"\u7f16\u7a0b\u521d\u5b66\u8005\u6700\u5bb9\u6613\u72af\u7684 5 \u4e2a\u9519\u8bef","text":"<p>\u505a\u5bb6\u6559\u7684\u65f6\u5019\u53d1\u73b0\uff0c\u65b0\u624b\u5b66\u7f16\u7a0b\u9047\u5230\u7684\u95ee\u9898\u9ad8\u5ea6\u91cd\u590d\u3002\u4ee5\u4e0b\u662f 5 \u4e2a\u6700\u5e38\u89c1\u7684\uff1a</p> <p>\u9519\u8bef\u4e00\uff1a\u53ea\u770b\u89c6\u9891\u4e0d\u52a8\u624b\u3002 \u770b\u6559\u7a0b\u7684\u65f6\u5019\u89c9\u5f97\"\u5f88\u7b80\u5355\u561b\"\uff0c\u5408\u4e0a\u89c6\u9891\u53d1\u73b0\u81ea\u5df1\u4e00\u884c\u90fd\u5199\u4e0d\u51fa\u6765\u3002 \u2192 \u6bcf\u770b 10 \u5206\u949f\u6559\u7a0b\uff0c\u81f3\u5c11\u6572 20 \u5206\u949f\u4ee3\u7801\u3002\u7f16\u7a0b\u662f\u808c\u8089\u8bb0\u5fc6\u3002</p> <p>\u9519\u8bef\u4e8c\uff1a\u6015\u62a5\u9519\u3002 \u770b\u5230\u7ea2\u8272\u5c31\u614c\uff0c\u4e0d\u6562\u8bfb\u9519\u8bef\u4fe1\u606f\uff0c\u76f4\u63a5\u622a\u5c4f\u95ee\u4eba\u3002 \u2192 \u9519\u8bef\u4fe1\u606f\u4e0d\u662f\u654c\u4eba\uff0c\u662f\u6700\u597d\u7684\u8001\u5e08\u3002\u5b83\u76f4\u63a5\u544a\u8bc9\u4f60\u95ee\u9898\u5728\u54ea\u884c\u3001\u662f\u4ec0\u4e48\u95ee\u9898\u3002</p> <p>\u9519\u8bef\u4e09\uff1a\u590d\u5236\u7c98\u8d34\u7efc\u5408\u5f81\u3002 \u4ece AI \u5de5\u5177\u590d\u5236\u4ee3\u7801\uff0c\u80fd\u8dd1\u5c31\u884c\uff0c\u4e0d\u6df1\u7a76\u539f\u7406\u3002 \u2192 \u53ef\u4ee5\u501f\u52a9 AI\uff0c\u4f46\u6bcf\u4e00\u884c\u90fd\u8981\u80fd\u81ea\u5df1\u89e3\u91ca\u3002\u89e3\u91ca\u4e0d\u4e86\u7684\u4ee3\u7801\u4e0d\u662f\u4f60\u7684\u3002</p> <p>\u9519\u8bef\u56db\uff1a\u57fa\u7840\u6ca1\u6253\u7262\u5c31\u60f3\u5199\u9879\u76ee\u3002 \u624d\u5b66\u4e86\u4e24\u5468 JavaScript \u5c31\u60f3\u505a\u5b8c\u6574\u7684\u5546\u57ce\u9879\u76ee\uff0c\u7ed3\u679c\u8d8a\u5199\u8d8a\u4e71\u3002 \u2192 \u5148\u628a\u57fa\u7840\u8bed\u6cd5\u3001\u6570\u636e\u64cd\u4f5c\u3001\u4e8b\u4ef6\u5904\u7406\u8fd9\u4e9b\u641e\u719f\uff0c\u518d\u4e0a\u6846\u67b6\u3002</p> <p>\u9519\u8bef\u4e94\uff1a\u81ea\u5df1\u95f7\u5934\u5b66\uff0c\u4e0d\u8ddf\u4eba\u4ea4\u6d41\u3002 \u2192 \u627e\u540c\u5b66\u505a\u4ee3\u7801\u8bc4\u5ba1\u3001\u5199\u6280\u672f\u6587\u7ae0\u3001\u53c2\u4e0e\u5f00\u6e90\u793e\u533a\u3002\u6559\u4f1a\u522b\u4eba\u7684\u540c\u65f6\u4f60\u5b66\u5230\u7684\u66f4\u591a\u3002</p>"},{"location":"blog/#a2","title":"\u4ece Figma \u5230\u4ee3\u7801\uff1a\u8bbe\u8ba1\u5e08\u5b66\u524d\u7aef\u600e\u4e48\u5165\u95e8","text":"<p>\u6211\u81ea\u5df1\u662f\u4ece Figma \u5207\u5165\u524d\u7aef\u7684\uff0c\u8fd9\u6761\u8def\u6709\u5929\u7136\u7684\u4f18\u52bf\uff1a</p> <ol> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u5e03\u5c40 \u2014 Flexbox/Grid \u5c31\u662f Figma \u7684 Auto Layout\uff0c\u6982\u5ff5\u4e00\u6a21\u4e00\u6837</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u5c42\u7ea7 \u2014 z-index \u5c31\u662f\u56fe\u5c42\u9762\u677f\u7684\u6570\u5b57\u7248</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u7ec4\u4ef6 \u2014 Figma Components = Vue/React \u7ec4\u4ef6</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u4ea4\u4e92 \u2014 \u539f\u578b\u8fde\u7ebf \u2248 \u4e8b\u4ef6\u5904\u7406</li> </ol> <pre><code>\u5b66\u4e60\u8def\u7ebf\uff1a\nFigma \u7ec4\u4ef6\u601d\u7ef4\n  \u2192 HTML \u7ed3\u6784\uff08\u76d2\u6a21\u578b\u3001\u8bed\u4e49\u5316\uff09\n    \u2192 CSS \u5e03\u5c40\uff08Flexbox\u3001Grid\uff09\n      \u2192 JavaScript \u57fa\u7840\uff08\u53d8\u91cf\u3001\u51fd\u6570\u3001\u4e8b\u4ef6\uff09\n        \u2192 Vue \u7ec4\u4ef6\u5f00\u53d1\n          \u2192 \"\u8bbe\u8ba1 + \u5de5\u7a0b\"\u53cc\u4fee\n</code></pre> <p>\u5173\u952e\u662f\u5fc3\u6001\uff1a\u4f60\u4e0d\u662f\u5728\"\u8f6c\u884c\"\uff0c\u800c\u662f\u5728\u62d3\u5c55\u6280\u80fd\u8fb9\u754c\u3002\u8bbe\u8ba1\u80fd\u529b\u662f\u4f60\u7684\u5dee\u5f02\u5316\u4f18\u52bf\u2014\u2014\u5927\u90e8\u5206\u7a0b\u5e8f\u5458\u4e0d\u4f1a\u505a\u8bbe\u8ba1\u3002</p>"},{"location":"blog/#a3","title":"AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4f1a\u88ab\u6dd8\u6c70\u5417\uff1f","text":"<p>\u6211\u7684\u7b54\u6848\u662f\uff1a\u4e0d\u4f1a\u88ab\u6dd8\u6c70\uff0c\u4f46\u5de5\u4f5c\u7684\u5185\u5bb9\u4f1a\u53d8\u5f97\u4e0d\u4e00\u6837\u3002</p> <p>AI \u80fd\u505a\u7684\u4e8b\uff1a\u751f\u6210\u6a21\u677f\u4ee3\u7801\u3001\u89e3\u91ca\u57fa\u672c\u6982\u5ff5\u3001\u8c03\u8bd5\u7b80\u5355\u9519\u8bef\u3001\u505a\u4ee3\u7801\u5ba1\u67e5\u3002\u8fd9\u4e9b\u4ee5\u524d\u662f\u8001\u5e08\u5de5\u4f5c\u7684\u4e00\u90e8\u5206\u3002</p> <p>AI \u505a\u4e0d\u4e86\u7684\u4e8b\uff1a\u5224\u65ad\u5b66\u751f\u5230\u5e95\u5361\u5728\u54ea\u91cc\u3001\u6839\u636e\u72b6\u6001\u8c03\u6574\u6559\u5b66\u8282\u594f\u3001\u8bbe\u8ba1\u5faa\u5e8f\u6e10\u8fdb\u7684\u5b66\u4e60\u8def\u5f84\u3001\u6fc0\u53d1\u5b66\u4e60\u52a8\u529b\u3001\u5206\u4eab\u771f\u5b9e\u7684\u9879\u76ee\u5751\u548c\u7ecf\u9a8c\u3002</p> <p>\u6240\u4ee5\u7f16\u7a0b\u8001\u5e08\u7684\u5de5\u4f5c\u4f1a\u4ece\"\u6559\u8bed\u6cd5\"\u8f6c\u5411\uff1a</p> <ol> <li>\u6559\u601d\u7ef4 \u2014 \u8ba1\u7b97\u601d\u7ef4\u3001\u95ee\u9898\u62c6\u89e3\u3001\u65b9\u6848\u8bbe\u8ba1</li> <li>\u6559\u534f\u4f5c \u2014 \u600e\u4e48\u548c AI \u9ad8\u6548\u914d\u5408\uff0c\u800c\u4e0d\u662f\u4f9d\u8d56</li> <li>\u6559\u5224\u65ad \u2014 \u600e\u4e48\u5206\u8fa8\u597d\u4ee3\u7801\u548c\u70c2\u4ee3\u7801</li> <li>\u6559\u5de5\u7a0b \u2014 \u5b9e\u9645\u9879\u76ee\u7684\u5de5\u4f5c\u6d41\u3001\u5de5\u5177\u94fe\u3001\u56e2\u961f\u534f\u4f5c</li> <li>\u6559\u8f6f\u6280\u80fd \u2014 \u6c9f\u901a\u3001\u6587\u6863\u3001\u4ee3\u7801\u8bc4\u5ba1</li> </ol> <p>\u4e00\u53e5\u8bdd\u603b\u7ed3\uff1aAI \u80fd\u628a\"\u77e5\u8bc6\u7684\u7b54\u6848\"\u7ed9\u4f60\uff0c\u4f46\u8001\u5e08\u6559\u7684\u662f\"\u627e\u5230\u7b54\u6848\u7684\u65b9\u6cd5\"\u3002</p>"},{"location":"blog/#a4","title":"Vue \u54cd\u5e94\u5f0f\u539f\u7406\u2014\u2014\u8bd5\u7740\u7528\u4eba\u8bdd\u8bb2\u6e05\u695a","text":"<p>\u4f60\u628a\u6570\u636e\u4ea4\u7ed9 Vue\uff0cVue \u5e2e\u4f60\u76ef\u7740\u3002\u6570\u636e\u4e00\u53d8\uff0c\u9875\u9762\u81ea\u52a8\u8ddf\u7740\u53d8\u3002</p> <p>\u4e09\u4e2a\u9700\u8981\u77e5\u9053\u7684\u8bcd\uff1a</p> <pre><code>\u6570\u636e (data)     \u2192  \u4f60\u5173\u5fc3\u7684\u72b6\u6001\uff0c\u6bd4\u5982 \"count = 0\"\n\u526f\u4f5c\u7528 (effect) \u2192  \u6570\u636e\u53d8\u4e86\u4f60\u8981\u505a\u4ec0\u4e48\uff0c\u6bd4\u5982 \"\u66f4\u65b0\u9875\u9762\u4e0a\u7684\u6570\u5b57\"\n\u8ffd\u8e2a (track)    \u2192  Vue \u5077\u5077\u8bb0\u4f4f\"\u8c01\u5728\u7528\u8fd9\u4e2a\u6570\u636e\"\n</code></pre> <p>\u6d41\u7a0b\u662f\u8fd9\u6837\u7684\uff1a</p> <pre><code>count = 5           \u2190 \u4f60\u6539\u4e86\u6570\u636e\n    \u2193\nProxy \u53d1\u73b0\u4e86         \u2190 Vue 3 \u7528 Proxy \u6697\u4e2d\u76d1\u542c\n    \u2193\n\"count \u6539\u4e86!\"        \u2190 \u901a\u77e5\u6240\u6709\u7528\u5230 count \u7684\u5730\u65b9\n    \u2193\n\u9875\u9762\u81ea\u52a8\u66f4\u65b0          \u2190 \u4f60\u4e0d\u7528\u7ba1\uff0cVue \u5e2e\u4f60\u641e\u5b9a\n</code></pre> <p>\u7528\u5916\u5356\u8ba2\u5355\u6765\u7c7b\u6bd4\uff1a</p> <ul> <li>\u6570\u636e = \u4f60\u7684\u8ba2\u5355\u72b6\u6001</li> <li>Proxy = \u5feb\u9012\u7cfb\u7edf\u5728\u540e\u53f0\u76ef\u7740</li> <li>\u526f\u4f5c\u7528 = \u72b6\u6001\u4e00\u53d8\u5c31\u7ed9\u4f60\u63a8\u901a\u77e5</li> <li>\u89c6\u56fe = \u4f60\u624b\u673a\u4e0a\u770b\u5230\u7684\u9875\u9762</li> </ul> <p>\u4f60\u4ece\u6765\u4e0d\u9700\u8981\u624b\u52a8\u5237\u65b0\u2014\u2014\u8fd9\u5c31\u662f\"\u54cd\u5e94\u5f0f\"\u3002</p>"},{"location":"blog/#_4","title":"\u6709\u4ec0\u4e48\u60f3\u804a\u7684\uff1f","text":"<p>\u6b22\u8fce\u90ae\u4ef6\u8054\u7cfb\u6216\u76f4\u63a5\u63d0 GitHub Issue\uff0c\u4e00\u8d77\u4ea4\u6d41\u3002</p> <p>\u270d\ufe0f \u8054\u7cfb\u6211</p>"},{"location":"projects/","title":"\u9879\u76ee\u4f5c\u54c1","text":"<p>\u4ee5\u4e0b\u662f\u6211\u5728\u5927\u5b66\u671f\u95f4\u5b8c\u6210\u7684\u51e0\u4e2a\u4ee3\u8868\u6027\u9879\u76ee\u3002\u6709\u7684\u5b8c\u6574\uff0c\u6709\u7684\u7c97\u7cd9\uff0c\u4f46\u6bcf\u4e2a\u90fd\u8ba9\u6211\u5b66\u5230\u4e86\u4e1c\u897f\u3002</p>"},{"location":"projects/#_2","title":"\u6bd5\u4e1a\u8bbe\u8ba1\uff1a\u6821\u56ed\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0","text":"<p>\u505a\u4e86\u4ec0\u4e48\u4e8b\uff1a\u4e3a\u5927\u5b66\u6821\u56ed\u8bbe\u8ba1\u5e76\u5b9e\u73b0\u4e86\u4e00\u4e2a\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0\u3002</p> <p>FigmaHTMLCSSJavaScript</p> <p>\u8fd9\u662f\u6211\u6700\u82b1\u5fc3\u601d\u7684\u4e00\u4e2a\u9879\u76ee\u3002\u4ece\u6700\u521d\u7684\u7528\u6237\u8c03\u7814\u5f00\u59cb\uff0c\u753b\u4fe1\u606f\u67b6\u6784\u3001\u505a\u7ebf\u6846\u56fe\u3001\u53cd\u590d\u8c03\u6574\u4ea4\u4e92\u7ec6\u8282\uff0c\u518d\u5230\u89c6\u89c9\u8bbe\u8ba1\u548c\u9ad8\u4fdd\u771f\u539f\u578b\u2014\u2014\u5728 Figma \u91cc\u78e8\u4e86\u5f88\u4e45\u3002\u505a\u5b8c\u8bbe\u8ba1\u7a3f\u4e4b\u540e\uff0c\u7528\u539f\u751f HTML/CSS/JS \u5b9e\u73b0\u4e86\u51e0\u4e2a\u6838\u5fc3\u9875\u9762\uff08\u5546\u54c1\u5217\u8868\u3001\u8be6\u60c5\u9875\u3001\u53d1\u5e03\u9875\u3001\u804a\u5929\u754c\u9762\uff09\uff0c\u4e5f\u505a\u4e86\u624b\u673a\u7aef\u7684\u9002\u914d\u3002</p> <p>\u5177\u4f53\u4ea7\u51fa\uff1a</p> <ul> <li>40+ \u9875\u9ad8\u4fdd\u771f Figma \u8bbe\u8ba1\u7a3f</li> <li>\u7ec4\u4ef6\u5e93\u548c\u8bbe\u8ba1\u89c4\u8303\u6587\u6863</li> <li>\u6838\u5fc3\u9875\u9762\u7684\u524d\u7aef\u5b9e\u73b0</li> <li>\u5b8c\u6574\u7684\u54cd\u5e94\u5f0f\u9002\u914d</li> </ul> <p>\u4ece\u4e2d\u5b66\u5230\u7684\uff1a\u8bbe\u8ba1\u4e0d\u662f\u753b\u56fe\uff0c\u662f\u89e3\u51b3\u95ee\u9898\u3002\u597d\u7684 UI \u8ba9\u7528\u6237\u4e0d\u7528\u601d\u8003\u5c31\u77e5\u9053\u4e0b\u4e00\u6b65\u8be5\u505a\u4ec0\u4e48\u3002</p>"},{"location":"projects/#_3","title":"\u4e2a\u4eba\u4f5c\u54c1\u96c6\u7f51\u7ad9","text":"<p>\u505a\u4e86\u4ec0\u4e48\u4e8b\uff1a\u4f60\u73b0\u5728\u6b63\u5728\u770b\u7684\u8fd9\u4e2a\u7f51\u7ad9\u3002</p> <p>PythonMkDocsCSSGitHub Pages</p> <p>\u8fd9\u4e2a\u7f51\u7ad9\u7684\u642d\u5efa\u8fc7\u7a0b\u5176\u5b9e\u633a\u6709\u610f\u601d\u7684\u2014\u2014\u5b83\u662f\u6211\u548c Claude Code \u534f\u4f5c\u5b8c\u6210\u7684\u3002\u6211\u544a\u8bc9 AI \u6211\u60f3\u8981\u4ec0\u4e48\u6548\u679c\uff0cAI \u5e2e\u6211\u5199\u4ee3\u7801\uff0c\u6211\u8d1f\u8d23\u51b3\u7b56\u548c\u8c03\u6574\u3002\u6574\u4e2a\u8fc7\u7a0b\u50cf\u4e00\u4e2a\"\u7ed3\u5bf9\u7f16\u7a0b\"\u7684\u7ec3\u4e60\u3002</p> <p>\u6280\u672f\u7ec6\u8282\uff1a</p> <ul> <li>\u57fa\u4e8e Python \u7684 MkDocs \u642d\u5efa\uff0c\u7528 Material Design \u4e3b\u9898</li> <li>\u624b\u5199\u4e86\u81ea\u5b9a\u4e49 CSS \u505a\u6837\u5f0f\u8c03\u6574</li> <li>\u6240\u6709\u5185\u5bb9\u7528 Markdown \u7f16\u5199</li> <li>\u901a\u8fc7 GitHub Pages \u514d\u8d39\u6258\u7ba1\uff0c\u4e00\u6761\u547d\u4ee4\u90e8\u7f72</li> </ul>"},{"location":"projects/#_4","title":"\u5176\u4ed6\u5b9e\u8df5","text":""},{"location":"projects/#_5","title":"\u5b66\u751f\u7ba1\u7406\u7cfb\u7edf","text":"Spring Boot + MyBatis + MySQL <p>\u4e00\u4e2a\u7b80\u5355\u7684 CRUD \u7cfb\u7edf\uff0c\u80fd\u7ba1\u7406\u5b66\u751f\u4fe1\u606f\u3001\u8bfe\u7a0b\u548c\u6210\u7ee9\u3002\u7528\u6765\u7ec3\u4e60 Spring Boot \u7684\u540e\u7aef\u5f00\u53d1\u6d41\u7a0b\u548c RESTful API \u8bbe\u8ba1\u3002</p>"},{"location":"projects/#_6","title":"\u5929\u6c14\u9884\u62a5\u5e94\u7528","text":"Vue 3 + Vite + \u5929\u6c14 API <p>\u8c03\u7528\u516c\u5f00\u7684\u5929\u6c14\u63a5\u53e3\uff0c\u505a\u4e00\u4e2a\u80fd\u5b9e\u65f6\u5c55\u793a\u5929\u6c14\u3001\u652f\u6301\u57ce\u5e02\u641c\u7d22\u548c\u672a\u6765\u9884\u62a5\u7684\u9875\u9762\u3002\u7ec3\u4e60\u4e86 Vue 3 \u7684 Composition API \u548c\u7ec4\u4ef6\u901a\u4fe1\u3002</p>"},{"location":"projects/#3d","title":"3D \u5c0f\u7403\u95ef\u5173","text":"Unity + C# <p>\u7528 Unity \u505a\u7684 3D \u5e73\u53f0\u8df3\u8dc3\u5c0f\u6e38\u620f\u3002\u63a7\u5236\u4e00\u4e2a\u7403\u6eda\u8fc7\u969c\u788d\u5230\u8fbe\u7ec8\u70b9\u3002\u867d\u7136\u5f88\u7b80\u964b\uff0c\u4f46\u4f53\u9a8c\u4e86\u6e38\u620f\u5f00\u53d1\u4ece\u5efa\u6a21\u5230\u811a\u672c\u7684\u5b8c\u6574\u6d41\u7a0b\u3002</p>"},{"location":"projects/#_7","title":"\u63a5\u4e0b\u6765\u60f3\u505a","text":"<ul> <li>\u505a\u4e00\u4e2a\u5e26\u5728\u7ebf\u4ee3\u7801\u7f16\u8f91\u5668\u7684\u7f16\u7a0b\u7ec3\u4e60\u5e73\u53f0</li> <li>\u5f55\u5236\u4e00\u7cfb\u5217\"\u4ece\u96f6\u5b66\u524d\u7aef\"\u7684\u6559\u5b66\u89c6\u9891</li> <li>\u628a Figma \u91cc\u79ef\u7d2f\u7684\u7ec4\u4ef6\u6574\u7406\u6210\u4e00\u4e2a\u5f00\u6e90\u7684 Vue \u7ec4\u4ef6\u5e93</li> </ul> <p>\u53bb GitHub \u770b\u770b</p>"}]}