{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83c\udfe0 \u9996\u9875","text":"\ud83d\udc68\u200d\ud83c\udfeb <p>\u957f\u6625\u79d1\u6280\u5b66\u9662 2025 \u5c4a\u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f\u6bd5\u4e1a\u751f\u3002\u5927\u5b66\u671f\u95f4\u7528 Figma \u72ec\u7acb\u5b8c\u6210\u4e86 40+ \u9875\u7684\u6bd5\u8bbe\u8bbe\u8ba1\u7a3f\uff0c\u505a\u8fc7 100+ \u8bfe\u65f6\u7684\u5bb6\u6559\u3002\u559c\u6b22\u8bbe\u8ba1\u548c\u4ee3\u7801\u4ea4\u53c9\u7684\u5730\u65b9\u2014\u2014\u80fd\u628a\u62bd\u8c61\u7684\u4e1c\u897f\u753b\u51fa\u6765\u3001\u505a\u51fa\u6765\u3001\u518d\u8bb2\u7ed9\u522b\u4eba\u542c\u3002</p>"},{"location":"#_1","title":"\u90ed\u7b11\u73ae","text":"<p>\u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f \u00b7 \u5e94\u8058\u7f16\u7a0b\u6559\u5e08</p>"},{"location":"#_2","title":"\u6280\u80fd","text":"<p>\u8bbe\u8ba1</p> <p>Figma \u662f\u6700\u719f\u7ec3\u7684\u5de5\u5177\uff0c\u80fd\u4ece\u7528\u6237\u8c03\u7814\u505a\u5230\u9ad8\u4fdd\u771f\u539f\u578b\u3002Photoshop\u3001Illustrator \u4e5f\u4f1a\u7528\u3002</p> <p>\u524d\u7aef</p> <p>HTML/CSS/JavaScript \u57fa\u7840\u624e\u5b9e\uff0cVue.js \u662f\u4e3b\u653b\u65b9\u5411\u3002\u4e86\u89e3\u54cd\u5e94\u5f0f\u5e03\u5c40\u548c\u7ec4\u4ef6\u5316\u5f00\u53d1\u3002</p> <p>\u540e\u7aef</p> <p>Java + Spring Boot + MyBatis\uff0c\u80fd\u642d\u57fa\u7840\u540e\u7aef\u670d\u52a1\u3002MySQL \u548c Linux \u4e5f\u90fd\u5b66\u8fc7\u3002</p> <p>AI \u5de5\u5177</p> <p>\u9ad8\u9891\u4f7f\u7528 Claude \u548c Claude Code \u8f85\u52a9\u5f00\u53d1\u2014\u2014\u8fd9\u4e2a\u7f51\u7ad9\u5c31\u662f\u548c AI \u534f\u4f5c\u642d\u5efa\u7684\u3002</p>"},{"location":"#_3","title":"\u4e3a\u4ec0\u4e48\u60f3\u505a\u7f16\u7a0b\u8001\u5e08","text":"<p>\u6211\u559c\u6b22\u6559\u3002 \u505a\u5bb6\u6559\u7684\u65f6\u5019\u53d1\u73b0\uff0c\u628a\u4e00\u4e2a\u590d\u6742\u7684\u4e1c\u897f\u62c6\u5f00\u3001\u7528\u5bf9\u65b9\u80fd\u542c\u61c2\u7684\u8bdd\u8bb2\u51fa\u6765\uff0c\u8fd9\u4e2a\u8fc7\u7a0b\u8ba9\u6211\u5f88\u6709\u6210\u5c31\u611f\u3002</p> <p>\u6211\u6709\u4e1c\u897f\u53ef\u6559\u3002 \u6211\u4ece\u8bbe\u8ba1\u5207\u5165\u7f16\u7a0b\u7684\u8fd9\u6761\u8def\uff0c\u521a\u597d\u77e5\u9053\u521d\u5b66\u8005\u4f1a\u8e29\u4ec0\u4e48\u5751\u3002\u6211\u8e29\u8fc7\u7684\u5751\uff0c\u53ef\u4ee5\u8ba9\u5b66\u751f\u5c11\u8d70\u5f2f\u8def\u3002</p> <p>\u6211\u8fd8\u5728\u5b66\u3002 \u8001\u5e08\u4e0d\u5e94\u8be5\u662f\"\u5168\u77e5\u5168\u80fd\"\u7684\uff0c\u800c\u5e94\u8be5\u662f\"\u548c\u5b66\u751f\u4e00\u8d77\u6210\u957f\"\u7684\u3002\u6211\u6bcf\u5929\u90fd\u5728\u7528 AI \u5de5\u5177\uff0c\u4e5f\u60f3\u628a\u8fd9\u79cd\u80fd\u529b\u6559\u7ed9\u5b66\u751f\u3002</p> <p>\u770b\u6211\u7684\u9879\u76ee \u2192 \u66f4\u591a\u5173\u4e8e\u6211 \u2192</p>"},{"location":"about/","title":"\u5173\u4e8e\u6211","text":"\u59d3\u540d \u90ed\u7b11\u73ae \u5b66\u5386 \u957f\u6625\u79d1\u6280\u5b66\u9662 \u00b7 \u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f \u00b7 \u672c\u79d1 \u6bd5\u4e1a 2025 \u5e74 \u6c42\u804c \u7f16\u7a0b\u6559\u5e08 GitHub @gxw072423"},{"location":"about/#_2","title":"\u7ecf\u5386","text":"2021 \u2014 2025 2022 \u2014 2023 2023 \u2014 2024 2024 \u2014 \u81f3\u4eca"},{"location":"about/#_3","title":"\u5927\u5b66\u56db\u5e74","text":"<p>\u5728\u957f\u6625\u79d1\u6280\u5b66\u9662\u8bfb\u8ba1\u7b97\u673a\u3002\u5b66\u4e86\u6570\u636e\u7ed3\u6784\u3001\u64cd\u4f5c\u7cfb\u7edf\u3001\u7f51\u7edc\u3001\u6570\u636e\u5e93\u3002\u4e0d\u662f\u6bcf\u95e8\u8bfe\u90fd\u559c\u6b22\uff0c\u4f46\u5199\u4ee3\u7801\u548c\u505a\u8bbe\u8ba1\u8fd9\u4e24\u4ef6\u4e8b\u8ba9\u6211\u4e00\u76f4\u6709\u70ed\u60c5\u3002</p>"},{"location":"about/#_4","title":"\u517c\u804c\u5bb6\u6559","text":"<p>\u63a5\u4e86\u521d\u4e2d\u751f\u8f85\u5bfc\u6570\u5b66\u7269\u7406\uff0c\u65ad\u65ad\u7eed\u7eed\u505a\u4e86 100+ \u8bfe\u65f6\u3002\u521a\u5f00\u59cb\u8bb2\u5f97\u5f88\u70c2\u2014\u2014\u4ee5\u4e3a\u628a\u6982\u5ff5\u8bf4\u6e05\u695a\u5c31\u884c\u4e86\u3002\u540e\u6765\u6162\u6162\u660e\u767d\uff1a\u6559\u5b66\u4e0d\u662f\u628a\u4f60\u77e5\u9053\u7684\u5012\u51fa\u6765\uff0c\u662f\u627e\u5230\u5bf9\u65b9\u80fd\u63a5\u4f4f\u7684\u8868\u8fbe\u65b9\u5f0f\u3002</p>"},{"location":"about/#_5","title":"\u6743\u76ca\u90e8 &amp; \u6bd5\u8bbe\u542f\u52a8","text":"<p>\u5f53\u4e86\u6821\u6743\u76ca\u90e8\u526f\u90e8\u957f\uff0c\u953b\u70bc\u4e86\u6c9f\u901a\u80fd\u529b\u3002\u540c\u65f6\u542f\u52a8\u4e86\u6bd5\u8bbe\u300a\u57fa\u4e8e Figma \u7684\u6821\u56ed\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0 UI \u8bbe\u8ba1\u4e0e\u5b9e\u73b0\u300b\u3002</p>"},{"location":"about/#ai","title":"\u6bd5\u8bbe\u5b8c\u6210 &amp; \u63a2\u7d22 AI","text":"<p>\u5b8c\u6210\u4e86 40+ \u9875\u9ad8\u4fdd\u771f\u8bbe\u8ba1\u7a3f + \u6838\u5fc3\u9875\u9762\u524d\u7aef\u5b9e\u73b0\u3002\u5f00\u59cb\u9ad8\u9891\u4f7f\u7528 Claude Code \u8f85\u52a9\u5f00\u53d1\u3002\u642d\u5efa\u4e86\u8fd9\u4e2a\u7f51\u7ad9\uff0c\u4e3a\u7f16\u7a0b\u6559\u5e08\u9762\u8bd5\u505a\u51c6\u5907\u3002</p>"},{"location":"about/#_6","title":"\u6280\u80fd","text":"<p>FigmaPhotoshopIllustratorAdobe XD</p> <p>HTML/CSSJavaScriptVue.js\u54cd\u5e94\u5f0f\u5e03\u5c40</p> <p>JavaSpring BootMyBatisMySQLLinux</p> <p>Claude / Claude CodeAI \u8bbe\u8ba1\u5de5\u5177Python</p>"},{"location":"about/#_7","title":"\u6211\u5bf9\u7f16\u7a0b\u6559\u5b66\u7684\u60f3\u6cd5","text":"<p>\u597d\u8001\u5e08\u4e0d\u662f\u628a\u7b80\u5355\u7684\u8bf4\u590d\u6742\u4e86\u663e\u5f97\u81ea\u5df1\u5389\u5bb3\uff0c\u800c\u662f\u628a\u590d\u6742\u7684\u8bf4\u7b80\u5355\u4e86\u8ba9\u5b66\u751f\u89c9\u5f97\"\u539f\u6765\u5982\u6b64\"\u3002</p> <ol> <li>\u4f1a\u7528 \u2014 \u80fd\u5199\u51fa\u80fd\u8dd1\u7684\u4ee3\u7801\uff0c\u89e3\u51b3\u57fa\u672c\u95ee\u9898</li> <li>\u4f1a\u60f3 \u2014 \u7406\u89e3\u5e95\u5c42\u539f\u7406\uff0c\u80fd\u81ea\u5df1\u5206\u6790\u95ee\u9898\u3001\u8bbe\u8ba1\u65b9\u6848</li> <li>\u4f1a\u6559 \u2014 \u80fd\u628a\u4f60\u61c2\u7684\u4e1c\u897f\uff0c\u7528\u522b\u4eba\u80fd\u7406\u89e3\u7684\u65b9\u5f0f\u8bb2\u6e05\u695a</li> </ol> <p>\u5927\u90e8\u5206\u8bfe\u7a0b\u53ea\u6559\u5230\u7b2c\u4e00\u5c42\u3002\u6211\u60f3\u505a\u7684\uff0c\u662f\u7528\u8bbe\u8ba1\u7684\u53ef\u89c6\u5316\u80fd\u529b\u964d\u4f4e\u95e8\u69db\uff0c\u7528\u5bb6\u6559\u7684\u8010\u5fc3\u5f15\u5bfc\u601d\u8003\uff0c\u7528 AI \u5de5\u5177\u63d0\u5347\u6548\u7387\u3002\u5728 AI \u65f6\u4ee3\uff0c\u8001\u5e08\u5e94\u8be5\u6559\u90a3\u4e9b AI \u66ff\u4ee3\u4e0d\u4e86\u7684\u4e1c\u897f\uff1a\u8ba1\u7b97\u601d\u7ef4\u3001\u95ee\u9898\u62c6\u89e3\u3001\u5224\u65ad\u597d\u574f\u4ee3\u7801\u3001\u548c AI \u9ad8\u6548\u534f\u4f5c\u3002</p>"},{"location":"about/#_8","title":"\u8054\u7cfb\u65b9\u5f0f","text":"<ul> <li>\ud83d\udce7 gxw072423@163.com</li> <li>\ud83d\udc19 github.com/gxw072423</li> </ul>"},{"location":"blog/","title":"\u6280\u672f\u6587\u7ae0","text":"<p>\u4e00\u4e9b\u5b66\u4e60\u548c\u6559\u5b66\u8fc7\u7a0b\u4e2d\u7684\u7b14\u8bb0\u548c\u601d\u8003\u3002</p>"},{"location":"blog/#5","title":"\u7f16\u7a0b\u521d\u5b66\u8005\u6700\u5bb9\u6613\u72af\u7684 5 \u4e2a\u9519\u8bef","text":"2025-07"},{"location":"blog/#figma","title":"\u4ece Figma \u5230\u4ee3\u7801\uff1a\u8bbe\u8ba1\u5e08\u5b66\u524d\u7aef\u600e\u4e48\u5165\u95e8","text":"2025-06"},{"location":"blog/#ai","title":"AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4f1a\u88ab\u6dd8\u6c70\u5417\uff1f","text":"2025-07"},{"location":"blog/#vue","title":"Vue \u54cd\u5e94\u5f0f\u539f\u7406\u2014\u2014\u8bd5\u7740\u7528\u4eba\u8bdd\u8bb2\u6e05\u695a","text":"2025-05"},{"location":"blog/#5_1","title":"\u7f16\u7a0b\u521d\u5b66\u8005\u6700\u5bb9\u6613\u72af\u7684 5 \u4e2a\u9519\u8bef","text":"<p>\u9519\u8bef\u4e00\uff1a\u53ea\u770b\u89c6\u9891\u4e0d\u52a8\u624b\u3002 \u770b\u6559\u7a0b\u89c9\u5f97\"\u5f88\u7b80\u5355\u561b\"\uff0c\u5408\u4e0a\u89c6\u9891\u53d1\u73b0\u81ea\u5df1\u4e00\u884c\u90fd\u5199\u4e0d\u51fa\u6765\u3002 \u2192 \u6bcf\u770b 10 \u5206\u949f\u6559\u7a0b\uff0c\u81f3\u5c11\u6572 20 \u5206\u949f\u4ee3\u7801\u3002\u7f16\u7a0b\u662f\u808c\u8089\u8bb0\u5fc6\u3002</p> <p>\u9519\u8bef\u4e8c\uff1a\u6015\u62a5\u9519\u3002 \u770b\u5230\u7ea2\u8272\u5c31\u614c\uff0c\u4e0d\u6562\u8bfb\u9519\u8bef\u4fe1\u606f\uff0c\u76f4\u63a5\u622a\u5c4f\u95ee\u4eba\u3002 \u2192 \u9519\u8bef\u4fe1\u606f\u4e0d\u662f\u654c\u4eba\uff0c\u662f\u6700\u597d\u7684\u8001\u5e08\u3002\u5b83\u76f4\u63a5\u544a\u8bc9\u4f60\u95ee\u9898\u5728\u54ea\u884c\u3001\u662f\u4ec0\u4e48\u95ee\u9898\u3002</p> <p>\u9519\u8bef\u4e09\uff1a\u590d\u5236 AI \u4ee3\u7801\u4e0d\u6df1\u7a76\u3002 \u80fd\u8dd1\u5c31\u884c\uff0c\u4e0d\u6df1\u7a76\u539f\u7406\u3002 \u2192 \u53ef\u4ee5\u501f\u52a9 AI\uff0c\u4f46\u6bcf\u4e00\u884c\u90fd\u8981\u80fd\u81ea\u5df1\u89e3\u91ca\u3002\u89e3\u91ca\u4e0d\u4e86\u7684\u4ee3\u7801\u4e0d\u662f\u4f60\u7684\u3002</p> <p>\u9519\u8bef\u56db\uff1a\u57fa\u7840\u6ca1\u6253\u7262\u5c31\u60f3\u5199\u5927\u9879\u76ee\u3002 \u5b66\u4e86\u4e24\u5468 JavaScript \u5c31\u60f3\u505a\u5546\u57ce\uff0c\u8d8a\u5199\u8d8a\u4e71\u3002 \u2192 \u5148\u628a\u57fa\u7840\u8bed\u6cd5\u3001\u6570\u636e\u64cd\u4f5c\u3001\u4e8b\u4ef6\u5904\u7406\u641e\u719f\uff0c\u518d\u4e0a\u6846\u67b6\u3002</p> <p>\u9519\u8bef\u4e94\uff1a\u81ea\u5df1\u95f7\u5934\u5b66\uff0c\u4e0d\u8ddf\u4eba\u4ea4\u6d41\u3002 \u2192 \u627e\u540c\u5b66\u505a\u4ee3\u7801\u8bc4\u5ba1\u3001\u5199\u6280\u672f\u6587\u7ae0\u3001\u53c2\u4e0e\u5f00\u6e90\u793e\u533a\u3002\u6559\u4f1a\u522b\u4eba\u65f6\u4f60\u5b66\u5230\u7684\u66f4\u591a\u3002</p>"},{"location":"blog/#figma_1","title":"\u4ece Figma \u5230\u4ee3\u7801\uff1a\u8bbe\u8ba1\u5e08\u5b66\u524d\u7aef\u600e\u4e48\u5165\u95e8","text":"<p>\u8bbe\u8ba1\u5e08\u5b66\u524d\u7aef\u6709\u5929\u7136\u7684\u4f18\u52bf\uff1a</p> <ol> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u5e03\u5c40 \u2014 Flexbox/Grid \u5c31\u662f Figma \u7684 Auto Layout</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u5c42\u7ea7 \u2014 z-index \u5c31\u662f\u56fe\u5c42\u9762\u677f</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u7ec4\u4ef6 \u2014 Figma Components = Vue/React \u7ec4\u4ef6</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u4ea4\u4e92 \u2014 \u539f\u578b\u8fde\u7ebf \u2248 \u4e8b\u4ef6\u5904\u7406</li> </ol> <p>\u5b66\u4e60\u8def\u7ebf\uff1aFigma \u7ec4\u4ef6\u601d\u7ef4 \u2192 HTML \u7ed3\u6784 \u2192 CSS \u5e03\u5c40 \u2192 JavaScript \u57fa\u7840 \u2192 Vue \u7ec4\u4ef6\u5f00\u53d1 \u2192 \"\u8bbe\u8ba1+\u5de5\u7a0b\"\u53cc\u4fee</p> <p>\u5173\u952e\u5fc3\u6001\uff1a\u4f60\u4e0d\u662f\u5728\"\u8f6c\u884c\"\uff0c\u662f\u5728\u62d3\u5c55\u6280\u80fd\u8fb9\u754c\u3002\u8bbe\u8ba1\u80fd\u529b\u662f\u4f60\u7684\u5dee\u5f02\u5316\u4f18\u52bf\u2014\u2014\u5927\u90e8\u5206\u7a0b\u5e8f\u5458\u4e0d\u4f1a\u505a\u8bbe\u8ba1\u3002</p>"},{"location":"blog/#ai_1","title":"AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4f1a\u88ab\u6dd8\u6c70\u5417\uff1f","text":"<p>\u6211\u7684\u7b54\u6848\u662f\uff1a\u4e0d\u4f1a\u88ab\u6dd8\u6c70\uff0c\u4f46\u5de5\u4f5c\u7684\u5185\u5bb9\u4f1a\u53d8\u3002</p> <p>AI \u80fd\u505a\u7684\uff1a\u751f\u6210\u6a21\u677f\u4ee3\u7801\u3001\u89e3\u91ca\u57fa\u672c\u6982\u5ff5\u3001\u8c03\u8bd5\u7b80\u5355\u9519\u8bef\u3001\u505a\u4ee3\u7801\u5ba1\u67e5\u3002</p> <p>AI \u505a\u4e0d\u4e86\u7684\uff1a\u5224\u65ad\u5b66\u751f\u5230\u5e95\u5361\u5728\u54ea\u91cc\u3001\u6839\u636e\u72b6\u6001\u8c03\u6574\u6559\u5b66\u8282\u594f\u3001\u8bbe\u8ba1\u5faa\u5e8f\u6e10\u8fdb\u7684\u5b66\u4e60\u8def\u5f84\u3001\u6fc0\u53d1\u5b66\u4e60\u52a8\u529b\u3001\u5206\u4eab\u771f\u5b9e\u7684\u9879\u76ee\u7ecf\u9a8c\u548c\u5751\u3002</p> <p>\u6240\u4ee5\u7f16\u7a0b\u8001\u5e08\u7684\u5de5\u4f5c\u4f1a\u4ece\"\u6559\u8bed\u6cd5\"\u8f6c\u5411\uff1a\u6559\u601d\u7ef4\u3001\u6559\u534f\u4f5c\u3001\u6559\u5224\u65ad\u3001\u6559\u5de5\u7a0b\u3001\u6559\u8f6f\u6280\u80fd\u3002</p> <p>AI \u80fd\u628a\"\u77e5\u8bc6\u7684\u7b54\u6848\"\u7ed9\u4f60\uff0c\u4f46\u8001\u5e08\u6559\u7684\u662f\"\u627e\u5230\u7b54\u6848\u7684\u65b9\u6cd5\"\u3002</p>"},{"location":"blog/#vue_1","title":"Vue \u54cd\u5e94\u5f0f\u539f\u7406\u2014\u2014\u8bd5\u7740\u7528\u4eba\u8bdd\u8bb2\u6e05\u695a","text":"<p>\u4f60\u628a\u6570\u636e\u4ea4\u7ed9 Vue\uff0cVue \u5e2e\u4f60\u76ef\u7740\u3002\u6570\u636e\u4e00\u53d8\uff0c\u9875\u9762\u81ea\u52a8\u8ddf\u7740\u53d8\u3002</p> <p>\u6570\u636e (data) \u2192 \u4f60\u5173\u5fc3\u7684\u72b6\u6001\uff0c\u6bd4\u5982 count = 0 \u526f\u4f5c\u7528 (effect) \u2192 \u6570\u636e\u53d8\u4e86\u8981\u505a\u4ec0\u4e48\uff0c\u6bd4\u5982\u66f4\u65b0\u9875\u9762 \u8ffd\u8e2a (track) \u2192 Vue \u5077\u5077\u8bb0\u4f4f\"\u8c01\u5728\u7528\u8fd9\u4e2a\u6570\u636e\"</p> <p>count = 5 \u2192 Proxy \u53d1\u73b0\u4e86 \u2192 \"count \u6539\u4e86!\" \u2192 \u9875\u9762\u81ea\u52a8\u66f4\u65b0</p> <p>\u7528\u5916\u5356\u8ba2\u5355\u6765\u7c7b\u6bd4\uff1a\u6570\u636e = \u4f60\u7684\u8ba2\u5355\u72b6\u6001\uff0cProxy = \u5feb\u9012\u7cfb\u7edf\u5728\u540e\u53f0\u76ef\u7740\uff0c\u526f\u4f5c\u7528 = \u72b6\u6001\u4e00\u53d8\u5c31\u7ed9\u4f60\u63a8\u901a\u77e5\uff0c\u89c6\u56fe = \u4f60\u624b\u673a\u4e0a\u770b\u5230\u7684\u9875\u9762\u3002</p> <p>\u4f60\u4ece\u6765\u4e0d\u9700\u8981\u624b\u52a8\u5237\u65b0\u2014\u2014\u8fd9\u5c31\u662f\"\u54cd\u5e94\u5f0f\"\u3002</p> <p>\u60f3\u4ea4\u6d41\u7684\u8bdd\uff0c\u6b22\u8fce\u90ae\u4ef6\u8054\u7cfb\uff1agxw072423@163.com</p>"},{"location":"projects/","title":"\u9879\u76ee\u4f5c\u54c1","text":""},{"location":"projects/#_2","title":"\u6bd5\u4e1a\u8bbe\u8ba1\uff1a\u6821\u56ed\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0","text":"Figma / HTML / CSS / JavaScript <p>\u8fd9\u662f\u6211\u82b1\u5fc3\u601d\u6700\u591a\u7684\u9879\u76ee\u3002\u4e3a\u5927\u5b66\u6821\u56ed\u505a\u4e86\u4e00\u6b3e\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0\u7684 UI \u8bbe\u8ba1\u548c\u524d\u7aef\u5b9e\u73b0\u3002</p> <p>\u4ece\u7528\u6237\u8c03\u7814\u5f00\u59cb\uff0c\u753b\u4fe1\u606f\u67b6\u6784\u3001\u505a\u7ebf\u6846\u56fe\uff0c\u518d\u5230\u89c6\u89c9\u8bbe\u8ba1\u548c\u9ad8\u4fdd\u771f\u539f\u578b\u2014\u2014\u5728 Figma \u91cc\u53cd\u590d\u6253\u78e8\u3002\u8bbe\u8ba1\u5b8c\u6210\u540e\uff0c\u7528\u539f\u751f HTML/CSS/JS \u5b9e\u73b0\u4e86\u5546\u54c1\u5217\u8868\u3001\u8be6\u60c5\u9875\u3001\u53d1\u5e03\u9875\u3001\u804a\u5929\u754c\u9762\u7b49\u6838\u5fc3\u9875\u9762\uff0c\u4e5f\u505a\u4e86\u54cd\u5e94\u5f0f\u9002\u914d\u3002</p> <p>\u5177\u4f53\u4ea7\u51fa\uff1a40+ \u9875 Figma \u9ad8\u4fdd\u771f\u8bbe\u8ba1\u7a3f\u3001\u7ec4\u4ef6\u5e93\u548c\u8bbe\u8ba1\u89c4\u8303\u3001\u6838\u5fc3\u9875\u9762\u4ee3\u7801\u3001\u624b\u673a\u548c\u684c\u9762\u7aef\u9002\u914d\u3002</p> <p>\u5b66\u5230\u7684\uff1a\u8bbe\u8ba1\u4e0d\u662f\u753b\u56fe\uff0c\u662f\u89e3\u51b3\u95ee\u9898\u3002\u597d\u7684 UI \u8ba9\u7528\u6237\u4e0d\u7528\u601d\u8003\u5c31\u77e5\u9053\u4e0b\u4e00\u6b65\u8be5\u505a\u4ec0\u4e48\u3002</p>"},{"location":"projects/#_3","title":"\u4e2a\u4eba\u4f5c\u54c1\u96c6\u7f51\u7ad9","text":"Python / MkDocs / CSS / GitHub Pages <p>\u5c31\u662f\u4f60\u6b63\u5728\u770b\u7684\u8fd9\u4e2a\u7f51\u7ad9\u3002\u548c Claude Code \u534f\u4f5c\u5b8c\u6210\u7684\u2014\u2014\u6211\u63cf\u8ff0\u60f3\u8981\u7684\u6548\u679c\uff0cAI \u5e2e\u6211\u5199\u4ee3\u7801\uff0c\u6211\u505a\u51b3\u7b56\u548c\u8c03\u6574\u3002\u6574\u4e2a\u8fc7\u7a0b\u50cf\u4e00\u6b21\"\u7ed3\u5bf9\u7f16\u7a0b\"\u3002</p> <p>\u6280\u672f\u7ec6\u8282\uff1a\u57fa\u4e8e MkDocs \u642d\u5efa\uff0c\u624b\u5199\u4e86\u81ea\u5b9a\u4e49 CSS\uff0c\u5168\u90e8\u5185\u5bb9\u7528 Markdown \u7f16\u5199\uff0c\u901a\u8fc7 GitHub Pages \u514d\u8d39\u6258\u7ba1\u3002</p>"},{"location":"projects/#_4","title":"\ud83c\udfa8 \u50cf\u7d20\u753b\u751f\u6210\u5668","text":"Vue 3 + Canvas API + GitHub Pages <p>\u72ec\u7acb\u5f00\u53d1\u7684\u4e00\u4e2a\u7eaf\u524d\u7aef\u56fe\u50cf\u5904\u7406\u5de5\u5177\u3002\u4e0a\u4f20\u7167\u7247\uff0c\u62d6\u52a8\u6ed1\u5757\u5c31\u80fd\u5b9e\u65f6\u770b\u5230\u50cf\u7d20\u5316\u6548\u679c\u2014\u2014\u652f\u6301\u539f\u59cb\u8272\u5f69\u3001\u590d\u53e46\u8272\u548c\u9ed1\u767d\u4e09\u79cd\u6a21\u5f0f\uff0c\u505a\u597d\u7684\u56fe\u53ef\u4ee5\u4e00\u952e\u4e0b\u8f7d PNG\u3002</p> <p> \u5728\u7ebf\u4f53\u9a8c  \u6e90\u7801</p>"},{"location":"projects/#python","title":"\ud83d\udc0d Python \u7f16\u7a0b\u7ec3\u4e60\u9898\u751f\u6210\u5668","text":"Python 3.12 \u00b7 \u96f6\u5916\u90e8\u4f9d\u8d56 \u00b7 \u7eaf\u6807\u51c6\u5e93 <p>\u4e00\u4e2a\u547d\u4ee4\u884c\u5de5\u5177\uff0c\u4e00\u884c\u547d\u4ee4\u81ea\u52a8\u751f\u6210\u7f16\u7a0b\u7ec3\u4e60\u9898\u3002\u8986\u76d6\u53d8\u91cf\u8fd0\u7b97\u3001\u6761\u4ef6\u5224\u65ad\u3001\u5faa\u73af\u3001\u51fd\u6570\u3001\u5217\u8868\u4e0e\u5b57\u7b26\u4e32 5 \u5927\u5206\u7c7b\uff0c\u6bcf\u9053\u9898\u90fd\u9644\u5e26\u53c2\u8003\u7b54\u6848\u548c\u6d4b\u8bd5\u7528\u4f8b\u2014\u2014\u62ff\u6765\u5c31\u80fd\u7528\u3002</p> <p>\u652f\u6301\u968f\u673a\u62bd\u9898\u3001\u6309\u5206\u7c7b\u548c\u96be\u5ea6\u7b5b\u9009\u3001\u6279\u91cf\u751f\u6210\u3001\u5bfc\u51fa Markdown \u6587\u4ef6\u3002</p> <p> \u6e90\u7801</p>"},{"location":"projects/#_5","title":"\u5176\u4ed6\u5b9e\u8df5","text":""},{"location":"projects/#_6","title":"\u5b66\u751f\u7ba1\u7406\u7cfb\u7edf","text":"Spring Boot + MyBatis + MySQL <p>\u4e00\u4e2a\u7b80\u5355\u7684 CRUD \u7cfb\u7edf\uff0c\u7ba1\u7406\u5b66\u751f\u4fe1\u606f\u3001\u8bfe\u7a0b\u548c\u6210\u7ee9\u3002\u7528\u6765\u7ec3\u4e60 Spring Boot \u540e\u7aef\u5f00\u53d1\u6d41\u7a0b\u548c RESTful API \u8bbe\u8ba1\u3002</p>"},{"location":"projects/#_7","title":"\u5929\u6c14\u9884\u62a5\u5e94\u7528","text":"Vue 3 + Vite + \u5929\u6c14 API <p>\u8c03\u7528\u516c\u5f00\u5929\u6c14\u63a5\u53e3\uff0c\u505a\u4e86\u4e2a\u80fd\u5b9e\u65f6\u5c55\u793a\u5929\u6c14\u3001\u652f\u6301\u57ce\u5e02\u641c\u7d22\u548c\u672a\u6765\u9884\u62a5\u7684\u9875\u9762\u3002\u7ec3\u4e60\u4e86 Vue 3 Composition API \u548c\u7ec4\u4ef6\u901a\u4fe1\u3002</p>"},{"location":"projects/#3d","title":"3D \u5c0f\u7403\u95ef\u5173","text":"Unity + C# <p>\u7528 Unity \u505a\u7684 3D \u5e73\u53f0\u8df3\u8dc3\u5c0f\u6e38\u620f\u3002\u63a7\u5236\u4e00\u4e2a\u7403\u6eda\u8fc7\u969c\u788d\u5230\u8fbe\u7ec8\u70b9\u3002\u4f53\u9a8c\u4e86\u6e38\u620f\u5f00\u53d1\u4ece\u5efa\u6a21\u5230\u811a\u672c\u7684\u5168\u6d41\u7a0b\u3002</p>"},{"location":"projects/#_8","title":"\u63a5\u4e0b\u6765\u60f3\u505a","text":"<ul> <li>\u5e26\u5728\u7ebf\u4ee3\u7801\u7f16\u8f91\u5668\u7684\u7f16\u7a0b\u7ec3\u4e60\u5e73\u53f0</li> <li>\"\u4ece\u96f6\u5b66\u524d\u7aef\"\u6559\u5b66\u89c6\u9891\u7cfb\u5217</li> <li>\u628a Figma \u7ec4\u4ef6\u6574\u7406\u6210\u5f00\u6e90 Vue \u7ec4\u4ef6\u5e93</li> </ul> <p>\u53bb GitHub \u770b\u770b \u2192</p>"}]}