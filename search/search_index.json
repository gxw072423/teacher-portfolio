{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u90ed\u7b11\u73ae","text":""},{"location":"#_2","title":"\u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f \u00b7 \u7f16\u7a0b\u6559\u5e08","text":"## \ud83d\udc4b \u4f60\u597d\uff0c\u6211\u662f\u90ed\u7b11\u73ae  \u6211\u662f\u4e00\u540d**\u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f**\u4e13\u4e1a\u7684\u5e94\u5c4a\u6bd5\u4e1a\u751f\uff0c\u70ed\u7231\u7f16\u7a0b\u6559\u5b66\u4e0e UI \u8bbe\u8ba1\u3002  \u6211\u76f8\u4fe1\u7f16\u7a0b\u4e0d\u5e94\u8be5\u662f\u67af\u71e5\u7684\u2014\u2014**\u597d\u7684\u6559\u5b66\u80fd\u8ba9\u590d\u6742\u7684\u77e5\u8bc6\u53d8\u5f97\u7b80\u5355\u6709\u8da3**\u3002\u6211\u64c5\u957f\u7528\u53ef\u89c6\u5316\u7684\u65b9\u5f0f\u89e3\u91ca\u6982\u5ff5\uff0c\u5e2e\u52a9\u5b66\u751f\u4ece\"\u4f1a\u7528\"\u5230\"\u4f1a\u60f3\"\u3002    \ud83d\udc68\u200d\ud83c\udfeb"},{"location":"#_3","title":"\u26a1 \u6280\u80fd\u901f\u89c8","text":"### \ud83c\udfa8 UI/UX \u8bbe\u8ba1 - **Figma** \u2014 \u6838\u5fc3\u6280\u80fd - Photoshop / Illustrator / XD - \u8bbe\u8ba1\u7cfb\u7edf\u642d\u5efa - \u54cd\u5e94\u5f0f\u8bbe\u8ba1     ### \ud83d\udda5\ufe0f \u524d\u7aef\u5f00\u53d1 - HTML5 / CSS3 / JavaScript - **Vue.js** \u2014 \u4e3b\u653b\u65b9\u5411 - \u54cd\u5e94\u5f0f\u5e03\u5c40 - \u524d\u7aef\u5de5\u7a0b\u5316\u57fa\u7840     ### \u2699\ufe0f \u540e\u7aef\u5f00\u53d1 - **Java** / Spring Boot - MyBatis / MySQL - Linux \u64cd\u4f5c\u7cfb\u7edf - Python / MkDocs     ### \ud83e\udd16 AI \u5de5\u5177 - Claude / Claude Code - AIGC \u8bbe\u8ba1\u5de5\u5177 - AI \u9a71\u52a8\u5168\u6d41\u7a0b\u5f00\u53d1 - \u667a\u80fd\u8c03\u8bd5\u4e0e\u4ee3\u7801\u5ba1\u67e5"},{"location":"#_4","title":"\ud83d\udccc \u6211\u4e3a\u4ec0\u4e48\u9002\u5408\u505a\u7f16\u7a0b\u8001\u5e08\uff1f","text":"### \ud83d\udd2c \u7406\u8bba\u4e0e\u5b9e\u8df5\u517c\u5907 \u8ba1\u7b97\u673a\u79d1\u73ed\u51fa\u8eab\uff0c\u4e86\u89e3\u5e95\u5c42\u539f\u7406\u3002\u80fd\u8bb2**\u662f\u4ec0\u4e48**\uff0c\u66f4\u80fd\u8bb2**\u4e3a\u4ec0\u4e48**\u3002     ### \ud83c\udfa8 \u8bbe\u8ba1 + \u4ee3\u7801\u53cc\u4fee Figma \u8bbe\u8ba1\u80fd\u529b\u7a81\u51fa\uff0c\u80fd\u7528**\u53ef\u89c6\u5316\u65b9\u5f0f**\u964d\u4f4e\u5b66\u4e60\u95e8\u69db\u3002UI/UX \u601d\u7ef4\u8ba9\u6211\u66f4\u61c2\"\u600e\u4e48\u505a\u624d\u597d\u7528\"\u3002     ### \ud83e\udd16 AI \u539f\u751f\u6559\u5b66\u89c2 \u6df1\u5ea6\u4f7f\u7528 AI \u5de5\u5177\u8f85\u52a9\u5f00\u53d1\uff0c\u7406\u89e3 AI \u65f6\u4ee3\u7a0b\u5e8f\u5458\u7684\u5de5\u4f5c\u6d41\u53d8\u9769\u3002**\u6559\u5b66\u751f\u7528 AI \u63d0\u6548\uff0c\u800c\u975e\u88ab AI \u66ff\u4ee3**\u3002     ### \ud83d\udc68\u200d\ud83c\udfeb \u6559\u5b66\u7ecf\u9a8c\u840c\u82bd \u5927\u5b66\u671f\u95f4\u517c\u804c\u5bb6\u6559\uff0c\u61c2\u5f97\u5982\u4f55\u56e0\u6750\u65bd\u6559\u3001\u8010\u5fc3\u5f15\u5bfc\u3002\u70ed\u7231\u5206\u4eab\u77e5\u8bc6\uff0c\u4e50\u4e8e\u770b\u89c1\u5b66\u751f\u6210\u957f\u3002     [\ud83d\ude80 \u770b\u770b\u6211\u7684\u9879\u76ee](projects.md){ .md-button .md-button--primary } [\ud83d\udc64 \u4e86\u89e3\u66f4\u591a](about.md){ .md-button }"},{"location":"about/","title":"\ud83d\udc64 \u5173\u4e8e\u6211","text":""},{"location":"about/#_2","title":"\u57fa\u672c\u4fe1\u606f","text":"\u9879\u76ee \u5185\u5bb9 \u59d3\u540d \u90ed\u7b11\u73ae \u5b66\u5386 \u957f\u6625\u79d1\u6280\u5b66\u9662 \u00b7 \u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f \u00b7 \u672c\u79d1 \u6bd5\u4e1a\u65f6\u95f4 2025 \u5e74 \u6c42\u804c\u610f\u5411 \u7f16\u7a0b\u6559\u5e08 GitHub @gxw072423"},{"location":"about/#_3","title":"\ud83c\udf93 \u6559\u80b2\u80cc\u666f","text":""},{"location":"about/#_4","title":"\u957f\u6625\u79d1\u6280\u5b66\u9662 \u00b7 \u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f","text":"<p>\u5728\u6821\u671f\u95f4\u7cfb\u7edf\u5b66\u4e60\u4e86\u8ba1\u7b97\u673a\u79d1\u5b66\u6838\u5fc3\u8bfe\u7a0b\uff0c\u5305\u62ec\u6570\u636e\u7ed3\u6784\u3001\u64cd\u4f5c\u7cfb\u7edf\u3001\u8ba1\u7b97\u673a\u7f51\u7edc\u3001\u6570\u636e\u5e93\u539f\u7406\u3001\u7f16\u7a0b\u8bed\u8a00\u7b49\u3002</p> <p>\u6bd5\u4e1a\u8bbe\u8ba1\uff1a\u300a\u57fa\u4e8e Figma \u7684\u6821\u56ed\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0 UI \u8bbe\u8ba1\u4e0e\u5b9e\u73b0\u300b</p> <p>\u6bd5\u8bbe\u9879\u76ee\u4ece\u7528\u6237\u7814\u7a76\u3001\u4fe1\u606f\u67b6\u6784\u3001\u4ea4\u4e92\u8bbe\u8ba1\u3001\u89c6\u89c9\u8bbe\u8ba1\u5230\u524d\u7aef\u5b9e\u73b0\u5b8c\u6210\u4e86\u4e00\u6761\u5b8c\u6574\u7684\u94fe\u8def\uff0c\u5728 Figma \u4e2d\u5b8c\u6210\u4e86 40+ \u4e2a\u9875\u9762\u7684\u9ad8\u4fdd\u771f\u8bbe\u8ba1\u7a3f\uff0c\u5e76\u4f7f\u7528 HTML/CSS/JavaScript \u5b9e\u73b0\u4e86\u6838\u5fc3\u4ea4\u4e92\u9875\u9762\u3002</p>"},{"location":"about/#_5","title":"\ud83d\udcbc \u6821\u56ed\u7ecf\u5386","text":""},{"location":"about/#_6","title":"\u6821\u6743\u76ca\u90e8\u526f\u90e8\u957f","text":"<ul> <li>\u7ec4\u7ec7\u534f\u8c03\u6821\u56ed\u6d3b\u52a8\uff0c\u953b\u70bc\u4e86\u6c9f\u901a\u4e0e\u56e2\u961f\u534f\u4f5c\u80fd\u529b</li> <li>\u8d1f\u8d23\u5b66\u751f\u6743\u76ca\u53cd\u9988\u6e20\u9053\u7684\u7ef4\u62a4\uff0c\u57f9\u517b\u4e86\u8010\u5fc3\u4e0e\u670d\u52a1\u610f\u8bc6</li> </ul>"},{"location":"about/#_7","title":"\u517c\u804c\u5bb6\u6559","text":"<ul> <li>\u8f85\u5bfc\u521d\u4e2d\u751f\u6570\u5b66\u4e0e\u7269\u7406\uff0c\u7d2f\u8ba1 100+ \u8bfe\u65f6</li> <li>\u5584\u4e8e\u5c06\u62bd\u8c61\u95ee\u9898\u62c6\u89e3\u4e3a\u53ef\u7406\u89e3\u7684\u6b65\u9aa4\uff0c\u5f15\u5bfc\u5b66\u751f\u81ea\u4e3b\u601d\u8003</li> <li>\u8fd9\u6bb5\u7ecf\u5386\u8ba9\u6211\u786e\u4fe1\uff1a\u6559\u5b66\u662f\u6211\u771f\u6b63\u70ed\u7231\u7684\u4e8b</li> </ul>"},{"location":"about/#_8","title":"\ud83d\udee0\ufe0f \u6280\u80fd\u8be6\u60c5","text":""},{"location":"about/#_9","title":"\u8bbe\u8ba1\u5de5\u5177","text":"\u2b50 Figma \u2014 \u6700\u719f\u7ec3 Adobe Photoshop Adobe Illustrator Adobe XD Sketch"},{"location":"about/#_10","title":"\u524d\u7aef\u6280\u672f","text":"HTML5 CSS3 JavaScript ES6+ \u2b50 Vue.js \u54cd\u5e94\u5f0f\u5e03\u5c40"},{"location":"about/#_11","title":"\u540e\u7aef &amp; \u6570\u636e\u5e93","text":"Java Spring Boot MyBatis MySQL Linux"},{"location":"about/#ai","title":"AI \u5de5\u5177\u94fe","text":"Claude / Claude Code AI \u8bbe\u8ba1\u5de5\u5177 Python"},{"location":"about/#_12","title":"\ud83c\udfaf \u7f16\u7a0b\u6559\u5b66\u7406\u5ff5","text":"<p>\"\u597d\u7684\u4ee3\u7801\u8001\u5e08\uff0c\u4e0d\u53ea\u662f\u6559\u8bed\u6cd5\uff0c\u800c\u662f\u6559\u601d\u7ef4\u65b9\u5f0f\u3002\"</p> <p>\u6211\u7406\u89e3\u7684\u7f16\u7a0b\u6559\u5b66\u5206\u4e3a\u4e09\u4e2a\u5c42\u6b21\uff1a</p> <ol> <li>\u4f1a\u7528 \u2014 \u80fd\u5199\u51fa\u80fd\u8dd1\u7684\u4ee3\u7801</li> <li>\u4f1a\u60f3 \u2014 \u7406\u89e3\u80cc\u540e\u7684\u539f\u7406\uff0c\u80fd\u81ea\u4e3b\u89e3\u51b3\u95ee\u9898</li> <li>\u4f1a\u6559 \u2014 \u80fd\u628a\u81ea\u5df1\u61c2\u7684\u4e1c\u897f\uff0c\u7528\u522b\u4eba\u80fd\u7406\u89e3\u7684\u65b9\u5f0f\u8bb2\u51fa\u6765</li> </ol> <p>\u6211\u7684\u76ee\u6807\u662f\u57f9\u517b\u5b66\u751f\u5728\u7b2c 2 \u5c42\u7ad9\u7a33\u811a\u8ddf\uff0c\u540c\u65f6\u7528\u81ea\u5df1\u7684\u8bbe\u8ba1\u80fd\u529b\u8ba9\u62bd\u8c61\u6982\u5ff5\u53ef\u89c6\u5316\uff0c\u964d\u4f4e\u7406\u89e3\u95e8\u69db\u3002</p> <p>\u5728 AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u7684\u89d2\u8272\u4e0d\u518d\u662f\"\u4ee3\u7801\u8bcd\u5178\"\uff0c\u800c\u662f\uff1a</p> <ul> <li>\ud83d\udd0d \u5e2e\u52a9\u5b66\u751f\u5efa\u7acb\u8ba1\u7b97\u601d\u7ef4</li> <li>\ud83e\udded \u5f15\u5bfc\u5b66\u751f\u5b66\u4f1a\u4e0e AI \u534f\u4f5c\u800c\u975e\u4f9d\u8d56</li> <li>\ud83c\udfaf \u6559\u4f1a\u5b66\u751f\u63d0\u95ee\u3001\u9a8c\u8bc1\u3001\u4f18\u5316\u7684\u80fd\u529b</li> </ul>"},{"location":"about/#_13","title":"\ud83d\udceb \u8054\u7cfb\u6211","text":"<ul> <li>\ud83d\udce7 Email: gxw072423@163.com</li> <li>\ud83d\udc19 GitHub: @gxw072423</li> <li>\ud83d\udccd \u6240\u5728\u5730: \u4e2d\u56fd</li> </ul>"},{"location":"blog/","title":"\ud83d\udcdd \u6280\u672f\u6587\u7ae0","text":"<p>\u5206\u4eab\u6211\u5728\u7f16\u7a0b\u5b66\u4e60\u4e0e\u6559\u5b66\u8fc7\u7a0b\u4e2d\u7684\u601d\u8003\u4e0e\u603b\u7ed3\u3002</p>"},{"location":"blog/#_2","title":"\ud83d\udcd6 \u6587\u7ae0\u5217\u8868","text":"### \ud83c\udfaf \u7f16\u7a0b\u521d\u5b66\u8005\u6700\u5bb9\u6613\u72af\u7684 5 \u4e2a\u9519\u8bef  \ud83d\udcc5 2025-07 \u6559\u5b66\u5fc3\u5f97  \u4ece\u5b9e\u9645\u6559\u5b66\u7ecf\u9a8c\u51fa\u53d1\uff0c\u603b\u7ed3\u521d\u5b66\u8005\u5e38\u89c1\u7684\u601d\u7ef4\u9677\u9631\u548c\u7ea0\u6b63\u65b9\u6cd5\u3002   \u9605\u8bfb\u5168\u6587 \u2192   ### \ud83c\udfa8 \u4ece Figma \u5230\u4ee3\u7801\uff1a\u8bbe\u8ba1\u5e08\u7684\u524d\u7aef\u5165\u95e8\u6307\u5357  \ud83d\udcc5 2025-06 \u8bbe\u8ba1 + \u5f00\u53d1  \u5982\u4f55\u5229\u7528 Figma \u7684\u8bbe\u8ba1\u80fd\u529b\u964d\u4f4e\u524d\u7aef\u5b66\u4e60\u95e8\u69db\uff0c\u8ba9\u89c6\u89c9\u601d\u7ef4\u6210\u4e3a\u7f16\u7a0b\u7684\u52a9\u529b\u3002   \u9605\u8bfb\u5168\u6587 \u2192   ### \ud83e\udd16 AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4f1a\u88ab\u53d6\u4ee3\u5417\uff1f  \ud83d\udcc5 2025-07 \u884c\u4e1a\u601d\u8003  \u63a2\u8ba8 AI \u5de5\u5177\u5bf9\u7f16\u7a0b\u6559\u80b2\u7684\u5f71\u54cd\uff0c\u4ee5\u53ca\u65b0\u65f6\u4ee3\u7f16\u7a0b\u6559\u5e08\u5e94\u8be5\u5177\u5907\u7684\u6838\u5fc3\u80fd\u529b\u3002   \u9605\u8bfb\u5168\u6587 \u2192   ### \ud83d\udcd0 Vue \u54cd\u5e94\u5f0f\u539f\u7406\u2014\u2014\u7528\u52a8\u753b\u89e3\u91ca\u7ed9\u4f60\u770b  \ud83d\udcc5 2025-05 \u524d\u7aef\u539f\u7406  \u7528 Figma \u5236\u4f5c\u7684\u56fe\u89e3\u52a8\u753b\uff0c\u4e00\u6b65\u6b65\u62c6\u89e3 Vue 3 \u7684\u54cd\u5e94\u5f0f\u7cfb\u7edf\u662f\u600e\u4e48\u5de5\u4f5c\u7684\u3002   \u9605\u8bfb\u5168\u6587 \u2192"},{"location":"blog/#_3","title":"\ud83d\udcdd \u6587\u7ae0\u5168\u6587","text":""},{"location":"blog/#5","title":"\ud83c\udfaf \u7f16\u7a0b\u521d\u5b66\u8005\u6700\u5bb9\u6613\u72af\u7684 5 \u4e2a\u9519\u8bef","text":""},{"location":"blog/#_4","title":"\u9519\u8bef\u4e00\uff1a\u53ea\u770b\u4e0d\u5199","text":"<p>\u5f88\u591a\u5b66\u751f\u82b1\u5927\u91cf\u65f6\u95f4\u770b\u89c6\u9891\u3001\u770b\u6559\u7a0b\uff0c\u4f46\u4ece\u6765\u4e0d\u81ea\u5df1\u52a8\u624b\u6572\u4ee3\u7801\u3002</p> <p>\u6b63\u786e\u505a\u6cd5\uff1a\u6bcf\u770b 10 \u5206\u949f\u6559\u7a0b\uff0c\u81f3\u5c11\u82b1 20 \u5206\u949f\u81ea\u5df1\u6572\u3002\u7f16\u7a0b\u662f\u808c\u8089\u8bb0\u5fc6\uff0c\u4e0d\u662f\u77e5\u8bc6\u8bb0\u5fc6\u3002</p>"},{"location":"blog/#_5","title":"\u9519\u8bef\u4e8c\uff1a\u5bb3\u6015\u62a5\u9519","text":"<p>\u770b\u5230\u7ea2\u8272\u62a5\u9519\u5c31\u614c\uff0c\u4e0d\u6562\u770b\u9519\u8bef\u4fe1\u606f\uff0c\u76f4\u63a5\u590d\u5236\u53bb\u95ee\u522b\u4eba\u3002</p> <p>\u6b63\u786e\u505a\u6cd5\uff1a\u9519\u8bef\u4fe1\u606f\u662f\u6700\u597d\u7684\u8001\u5e08\u3002\u5148\u9759\u4e0b\u5fc3\u8bfb\u4e00\u904d\u2014\u2014\u5927\u591a\u6570\u62a5\u9519\u90fd\u76f4\u63a5\u544a\u8bc9\u4f60\u95ee\u9898\u5728\u54ea\u4e00\u884c\u3001\u662f\u4ec0\u4e48\u95ee\u9898\u3002</p>"},{"location":"blog/#_6","title":"\u9519\u8bef\u4e09\uff1a\u590d\u5236\u7c98\u8d34\u7efc\u5408\u5f81","text":"<p>\u4ece StackOverflow \u6216 AI \u5de5\u5177\u590d\u5236\u4ee3\u7801\uff0c\u80fd\u7528\u5c31\u884c\uff0c\u4e0d\u6df1\u7a76\u539f\u7406\u3002</p> <p>\u6b63\u786e\u505a\u6cd5\uff1a\u53ef\u4ee5\u501f\u52a9 AI \u5de5\u5177\uff0c\u4f46\u6bcf\u4e00\u884c\u4f60\u90fd\u8981\u80fd\u89e3\u91ca\u7ed9\u522b\u4eba\u542c\u3002\u89e3\u91ca\u4e0d\u4e86\u7684\u4ee3\u7801\uff0c\u4e0d\u662f\u4f60\u7684\u4ee3\u7801\u3002</p>"},{"location":"blog/#_7","title":"\u9519\u8bef\u56db\uff1a\u8ffd\u6c42\"\u6700\u4f18\u89e3\"","text":"<p>\u5728\u57fa\u7840\u8fd8\u4e0d\u624e\u5b9e\u65f6\uff0c\u7ea0\u7ed3\u4e8e\u7b97\u6cd5\u4f18\u5316\u3001\u8bbe\u8ba1\u6a21\u5f0f\u3001\u67b6\u6784\u9009\u62e9\u3002</p> <p>\u6b63\u786e\u505a\u6cd5\uff1a\u5148\u8ba9\u4ee3\u7801\u8dd1\u8d77\u6765\uff0c\u518d\u8ba9\u4ee3\u7801\u53d8\u597d\u3002\u8fc7\u65e9\u4f18\u5316\u662f\u4e07\u6076\u4e4b\u6e90\u3002</p>"},{"location":"blog/#_8","title":"\u9519\u8bef\u4e94\uff1a\u5b64\u519b\u594b\u6218","text":"<p>\u4e00\u4e2a\u4eba\u95f7\u5934\u5b66\uff0c\u4e0d\u4e0e\u522b\u4eba\u4ea4\u6d41\uff0c\u4e0d\u5c55\u793a\u81ea\u5df1\u7684\u4ee3\u7801\u3002</p> <p>\u6b63\u786e\u505a\u6cd5\uff1a\u53c2\u4e0e\u5f00\u6e90\u793e\u533a\u3001\u5199\u6280\u672f\u6587\u7ae0\u3001\u548c\u540c\u5b66\u505a\u4ee3\u7801\u8bc4\u5ba1\uff08Code Review\uff09\u3002\u6559\u4f1a\u522b\u4eba\u7684\u540c\u65f6\uff0c\u4f60\u5b66\u5230\u7684\u66f4\u591a\u3002</p>"},{"location":"blog/#figma","title":"\ud83c\udfa8 \u4ece Figma \u5230\u4ee3\u7801\uff1a\u8bbe\u8ba1\u5e08\u7684\u524d\u7aef\u5165\u95e8\u6307\u5357","text":"<p>\u4f5c\u4e3a\u4e00\u4e2a\u4ece Figma \u8f6c\u5411\u524d\u7aef\u5f00\u53d1\u7684\u4eba\uff0c\u6211\u60f3\u5206\u4eab\u4e00\u4e9b\u8de8\u754c\u7684\u7ecf\u9a8c\u3002</p>"},{"location":"blog/#_9","title":"\u4e3a\u4ec0\u4e48\u8bbe\u8ba1\u5e08\u5b66\u524d\u7aef\u6709\u5929\u7136\u4f18\u52bf\uff1f","text":"<ol> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u5e03\u5c40 \u2014 Flexbox \u548c Grid \u672c\u8d28\u4e0a\u5c31\u662f Figma \u7684 Auto Layout</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u5c42\u7ea7 \u2014 z-index \u5c31\u662f\u56fe\u5c42\u9762\u677f\u7684\u6570\u5b57\u7248</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u7ec4\u4ef6 \u2014 Figma Components = \u524d\u7aef\u7ec4\u4ef6\uff0c\u6982\u5ff5\u5b8c\u5168\u4e00\u81f4</li> <li>\u4f60\u5df2\u7ecf\u61c2\u4e86\u4ea4\u4e92 \u2014 \u539f\u578b\u8fde\u7ebf \u2248 \u4e8b\u4ef6\u5904\u7406\u903b\u8f91</li> </ol>"},{"location":"blog/#_10","title":"\u5b66\u4e60\u8def\u5f84\u5efa\u8bae","text":"<pre><code>Figma \u7ec4\u4ef6\u601d\u7ef4\n    \u2193\nHTML \u7ed3\u6784\uff08\u76d2\u6a21\u578b\u3001\u8bed\u4e49\u5316\uff09\n    \u2193\nCSS \u5e03\u5c40\uff08Flexbox\u3001Grid\uff09\n    \u2193\nJavaScript \u57fa\u7840\uff08\u53d8\u91cf\u3001\u51fd\u6570\u3001\u4e8b\u4ef6\uff09\n    \u2193\nVue/React \u7ec4\u4ef6\u5f00\u53d1\n    \u2193\n\u6210\u4e3a\u4e00\u4e2a\"\u8bbe\u8ba1\u5de5\u7a0b\u53cc\u4fee\"\u7684\u5168\u80fd\u5f00\u53d1\u8005\n</code></pre>"},{"location":"blog/#_11","title":"\u5173\u952e\u5fc3\u6001","text":"<p>\u4e0d\u8981\u628a\u81ea\u5df1\u5f53\u6210\"\u8f6c\u884c\"\uff0c\u800c\u662f\u62d3\u5c55\u6280\u80fd\u8fb9\u754c\u3002\u8bbe\u8ba1\u80fd\u529b\u6c38\u8fdc\u662f\u4f60\u7684\u5dee\u5f02\u5316\u4f18\u52bf\u2014\u2014\u5927\u591a\u6570\u7a0b\u5e8f\u5458\u505a\u4e0d\u5230\u597d\u770b\u7684\u8bbe\u8ba1\uff0c\u800c\u4f60\u53ef\u4ee5\u3002</p>"},{"location":"blog/#ai","title":"\ud83e\udd16 AI \u65f6\u4ee3\uff0c\u7f16\u7a0b\u8001\u5e08\u4f1a\u88ab\u53d6\u4ee3\u5417\uff1f","text":"<p>\u8fd9\u662f\u6bcf\u4e2a\u7f16\u7a0b\u6559\u80b2\u8005\u90fd\u9700\u8981\u9762\u5bf9\u7684\u95ee\u9898\u3002\u6211\u7684\u7b54\u6848\u662f\uff1a</p> <p>\u4e0d\u4f1a\u88ab\u53d6\u4ee3\uff0c\u4f46\u5fc5\u987b\u8f6c\u578b\u3002</p>"},{"location":"blog/#ai_1","title":"AI \u64c5\u957f\u4ec0\u4e48\uff1f","text":"<ul> <li>\u2705 \u751f\u6210\u6837\u677f\u4ee3\u7801</li> <li>\u2705 \u89e3\u91ca\u5df2\u77e5\u6982\u5ff5</li> <li>\u2705 \u8c03\u8bd5\u7b80\u5355\u9519\u8bef</li> <li>\u2705 \u63d0\u4f9b\u4ee3\u7801\u5ba1\u67e5\u5efa\u8bae</li> </ul>"},{"location":"blog/#ai_2","title":"AI \u505a\u4e0d\u4e86\u4ec0\u4e48\uff1f","text":"<ul> <li>\u274c \u7406\u89e3\u5b66\u751f\u7684\u771f\u5b9e\u56f0\u60d1\u70b9\uff08\u6709\u65f6\u5019\u5b66\u751f\u81ea\u5df1\u90fd\u8bf4\u4e0d\u6e05\u54ea\u91cc\u4e0d\u61c2\uff09</li> <li>\u274c \u6839\u636e\u5b66\u751f\u8868\u60c5/\u8bed\u6c14\u8c03\u6574\u6559\u5b66\u8282\u594f</li> <li>\u274c \u8bbe\u8ba1\u5faa\u5e8f\u6e10\u8fdb\u7684\u5b66\u4e60\u8def\u5f84</li> <li>\u274c \u6fc0\u53d1\u5b66\u4e60\u52a8\u529b\u548c\u4fdd\u6301\u5b66\u4e60\u70ed\u60c5</li> <li>\u274c \u4f20\u6388\u5b9e\u9645\u9879\u76ee\u7ecf\u9a8c\u548c\u5de5\u7a0b\u601d\u7ef4\u65b9\u5f0f</li> </ul>"},{"location":"blog/#_12","title":"\u65b0\u65f6\u4ee3\u7f16\u7a0b\u6559\u5e08\u7684\u6838\u5fc3\u80fd\u529b","text":"<ol> <li>AI \u534f\u4f5c\u6559\u5b66 \u2014 \u6559\u5b66\u751f\u5982\u4f55\u4e0e AI \u9ad8\u6548\u534f\u4f5c\uff0c\u800c\u975e\u7981\u6b62\u4f7f\u7528</li> <li>\u601d\u7ef4\u8bad\u7ec3 \u2014 \u4ece\"\u6559\u8bed\u6cd5\"\u8f6c\u5411\"\u6559\u601d\u7ef4\"</li> <li>\u9879\u76ee\u9a71\u52a8 \u2014 \u901a\u8fc7\u771f\u5b9e\u9879\u76ee\u8ba9\u5b66\u751f\u7406\u89e3\u5de5\u7a0b\u5168\u6d41\u7a0b</li> <li>\u8f6f\u6280\u80fd\u57f9\u517b \u2014 \u6c9f\u901a\u3001\u534f\u4f5c\u3001\u4ee3\u7801\u8bc4\u5ba1\u3001\u6280\u672f\u5199\u4f5c</li> <li>\u4e2a\u6027\u5316\u6307\u5bfc \u2014 AI \u63d0\u4f9b\u901a\u7528\u7b54\u6848\uff0c\u8001\u5e08\u63d0\u4f9b\u4e2a\u6027\u5316\u53cd\u9988</li> </ol>"},{"location":"blog/#vue","title":"\ud83d\udcd0 Vue \u54cd\u5e94\u5f0f\u539f\u7406\u2014\u2014\u7528\u52a8\u753b\u89e3\u91ca\u7ed9\u4f60\u770b","text":"<p>Vue 3 \u7684\u54cd\u5e94\u5f0f\u7cfb\u7edf\u662f\u5176\u6838\u5fc3\u7279\u6027\u3002\u8ba9\u6211\u7528\u6700\u7b80\u5355\u7684\u8bed\u8a00\u89e3\u91ca\u6e05\u695a\u3002</p>"},{"location":"blog/#_13","title":"\u4e00\u53e5\u8bdd\u6982\u62ec","text":"<p>\u4f60\u628a\u6570\u636e\u653e\u8fdb Vue\uff0cVue \u5e2e\u4f60\u76ef\u7740\u3002\u6570\u636e\u4e00\u53d8\uff0c\u9875\u9762\u81ea\u52a8\u8ddf\u7740\u53d8\u3002</p>"},{"location":"blog/#_14","title":"\u4e09\u4e2a\u6838\u5fc3\u6982\u5ff5","text":"<pre><code>\u6570\u636e (data)           \u2192  \u4f60\u5173\u5fc3\u7684\u503c\n\u526f\u4f5c\u7528 (effect)       \u2192  \u6570\u636e\u53d8\u5316\u65f6\u8981\u505a\u4ec0\u4e48\n\u4f9d\u8d56\u8ffd\u8e2a (tracking)  \u2192  Vue \u5077\u5077\u8bb0\u5f55\"\u8c01\u7528\u4e86\u8c01\"\n</code></pre>"},{"location":"blog/#_15","title":"\u56fe\u89e3\u6d41\u7a0b","text":"<pre><code>\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502  \u4fee\u6539\u6570\u636e    \u2502\n\u2502  data.x = 5 \u2502\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n       \u2502\n       \u25bc\n\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502  Proxy \u62e6\u622a  \u2502  \u2190 Vue 3 \u7528 Proxy \u76d1\u542c\u6570\u636e\u53d8\u5316\n\u2502  set trap   \u2502\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n       \u2502\n       \u25bc\n\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502  \u901a\u77e5\u4f9d\u8d56    \u2502  \u2190 \"\u5582\uff0c\u7528\u5230\u4e86 x \u7684\u90a3\u4e2a\u7ec4\u4ef6\uff0c\u4f60\u8981\u66f4\u65b0\u4e86\uff01\"\n\u2502  trigger    \u2502\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u252c\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n       \u2502\n       \u25bc\n\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502  \u91cd\u65b0\u6e32\u67d3    \u2502  \u2190 \u9875\u9762\u81ea\u52a8\u66f4\u65b0\uff0c\u53ea\u6539\u53d8\u5316\u7684\u90e8\u5206\n\u2502  re-render  \u2502\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n</code></pre>"},{"location":"blog/#_16","title":"\u7c7b\u6bd4\u7406\u89e3","text":"<p>\u628a Vue \u7684\u54cd\u5e94\u5f0f\u7cfb\u7edf\u60f3\u8c61\u6210\u5916\u5356\u8ba2\u5355\u8ddf\u8e2a\uff1a</p> <ul> <li>\u6570\u636e = \u4f60\u7684\u8ba2\u5355</li> <li>Proxy = \u5feb\u9012\u7cfb\u7edf\u7684\u8ddf\u8e2a\u6a21\u5757</li> <li>\u526f\u4f5c\u7528 = \u6bcf\u5f53\u8ba2\u5355\u72b6\u6001\u53d8\u5316\u65f6\uff0c\u7ed9\u4f60\u7684\u624b\u673a\u53d1\u901a\u77e5</li> <li>\u89c6\u56fe = \u4f60\u624b\u673a\u4e0a\u770b\u5230\u7684\u8ba2\u5355\u72b6\u6001\u9875\u9762</li> </ul> <p>\u4f60\u4e0d\u9700\u8981\u624b\u52a8\u5237\u65b0\u9875\u9762\u770b\u72b6\u6001\uff0c\u7cfb\u7edf\u4f1a\u81ea\u52a8\u901a\u77e5\u4f60\u2014\u2014\u8fd9\u5c31\u662f\"\u54cd\u5e94\u5f0f\"\u7684\u672c\u8d28\u3002</p>   ### \ud83d\udcec \u60f3\u4e86\u89e3\u66f4\u591a\uff1f  \u6211\u4f1a\u6301\u7eed\u66f4\u65b0\u6280\u672f\u6587\u7ae0\uff0c\u6b22\u8fce\u5173\u6ce8\u6211\u7684 [GitHub](https://github.com/gxw072423) \u6216\u901a\u8fc7\u90ae\u4ef6\u8054\u7cfb\u3002  [\u270d\ufe0f \u8054\u7cfb\u6211](about.md#_5){ .md-button }"},{"location":"projects/","title":"\ud83d\ude80 \u9879\u76ee\u4f5c\u54c1","text":"<p>\u6bcf\u4e00\u4e2a\u9879\u76ee\u90fd\u4ee3\u8868\u7740\u6211\u7684\u4e00\u6b65\u6210\u957f\u3002\u4ee5\u4e0b\u662f\u6211\u5728\u5b66\u4e60\u4e0e\u5b9e\u8df5\u4e2d\u5b8c\u6210\u7684\u4ee3\u8868\u6027\u4f5c\u54c1\u3002</p>"},{"location":"projects/#_2","title":"\ud83c\udf93 \u6bd5\u4e1a\u8bbe\u8ba1\uff1a\u6821\u56ed\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0","text":"**\u89d2\u8272**\uff1aUI/UX \u8bbe\u8ba1\u5e08 + \u524d\u7aef\u5f00\u53d1\u8005  **\u6280\u672f\u6808**\uff1a Figma HTML5 CSS3 JavaScript  ### \ud83d\udccb \u9879\u76ee\u6982\u8ff0  \u4e3a\u5927\u5b66\u6821\u56ed\u8bbe\u8ba1\u5e76\u5b9e\u73b0\u4e86\u4e00\u6b3e\u4e8c\u624b\u4ea4\u6613\u5e73\u53f0\u7684\u5b8c\u6574 UI\u3002\u4ece\u9700\u6c42\u8c03\u7814\u5230\u9ad8\u4fdd\u771f\u539f\u578b\uff0c\u518d\u5230\u524d\u7aef\u5b9e\u73b0\uff0c\u8d70\u5b8c\u4e86\u5168\u6d41\u7a0b\u3002  ### \u2705 \u5b8c\u6210\u4e86\u4ec0\u4e48  - \ud83c\udfa8 **40+ \u9875\u9762**\u9ad8\u4fdd\u771f Figma \u8bbe\u8ba1\u7a3f - \ud83d\udd0d \u8fdb\u884c\u7528\u6237\u8c03\u7814\u4e0e\u7ade\u54c1\u5206\u6790\uff0c\u4ea7\u51fa\u7528\u6237\u753b\u50cf - \ud83d\udcd0 \u642d\u5efa\u7ec4\u4ef6\u5e93\u548c\u8bbe\u8ba1\u89c4\u8303\uff08Design System\uff09 - \ud83d\udcbb \u4f7f\u7528 HTML/CSS/JS \u5b9e\u73b0\u6838\u5fc3\u9875\u9762\uff08\u5546\u54c1\u5217\u8868\u3001\u8be6\u60c5\u3001\u53d1\u5e03\u3001\u804a\u5929\uff09 - \ud83d\udcf1 \u5b8c\u6574\u7684\u54cd\u5e94\u5f0f\u9002\u914d\uff08\u624b\u673a\u7aef + \u684c\u9762\u7aef\uff09  ### \ud83d\udca1 \u6559\u5b66\u89c6\u89d2  &gt; \u8fd9\u4e2a\u9879\u76ee\u5c55\u793a\u4e86\u5982\u4f55\u5c06**\u8bbe\u8ba1\u601d\u7ef4**\u4e0e**\u5de5\u7a0b\u5b9e\u73b0**\u7ed3\u5408\u2014\u2014\u8fd9\u6b63\u662f\u6211\u5e0c\u671b\u6559\u7ed9\u5b66\u751f\u7684\uff1a\u5b66\u4f1a\u4ece\u7528\u6237\u89c6\u89d2\u601d\u8003\uff0c\u518d\u7528\u4ee3\u7801\u843d\u5730\u3002"},{"location":"projects/#_3","title":"\ud83d\udcbc \u4e2a\u4eba\u4f5c\u54c1\u96c6\u7f51\u7ad9","text":"**\u89d2\u8272**\uff1a\u5168\u6808\u5f00\u53d1\u8005  **\u6280\u672f\u6808**\uff1a Python MkDocs Material Design GitHub Pages  ### \ud83d\udccb \u9879\u76ee\u6982\u8ff0  \u4f60\u73b0\u5728\u6b63\u5728\u770b\u7684\u8fd9\u4e2a\u7f51\u7ad9\uff01\u4f7f\u7528 Python \u751f\u6001\u7684 MkDocs \u642d\u5efa\uff0cMaterial Design \u98ce\u683c\uff0c\u90e8\u7f72\u5728 GitHub Pages \u4e0a\u3002  ### \u2705 \u6280\u672f\u4eae\u70b9  - \ud83d\udc0d **Python \u5de5\u5177\u94fe**\uff1aMkDocs + Material for MkDocs - \ud83d\udcdd **Markdown \u9a71\u52a8**\uff1a\u6240\u6709\u5185\u5bb9\u4f7f\u7528 Markdown \u7f16\u5199\uff0c\u7b80\u6d01\u9ad8\u6548 - \ud83c\udfa8 **\u84dd\u8272\u4e3b\u9898**\uff1a\u7edf\u4e00\u7684 Material Design \u84dd\u8272\u8c03 - \ud83c\udf17 **\u6697\u8272\u6a21\u5f0f**\uff1a\u652f\u6301\u4eae\u8272/\u6697\u8272\u4e00\u952e\u5207\u6362 - \ud83d\ude80 **GitHub Pages \u90e8\u7f72**\uff1a\u4e00\u6761\u547d\u4ee4\u81ea\u52a8\u90e8\u7f72 - \ud83d\udd0d **\u5168\u6587\u641c\u7d22**\uff1a\u5185\u7f6e\u641c\u7d22\u529f\u80fd"},{"location":"projects/#_4","title":"\ud83d\udcda \u5176\u4ed6\u6280\u672f\u5b9e\u8df5","text":"### \ud83d\uddc4\ufe0f \u5b66\u751f\u7ba1\u7406\u7cfb\u7edf\uff08Java\uff09  **\u6280\u672f\u6808**\uff1aSpring Boot + MyBatis + MySQL  \u57fa\u7840\u7684 CRUD \u7ba1\u7406\u7cfb\u7edf\uff0c\u5305\u542b\u5b66\u751f\u4fe1\u606f\u7ba1\u7406\u3001\u8bfe\u7a0b\u7ba1\u7406\u3001\u6210\u7ee9\u5f55\u5165\u4e0e\u67e5\u8be2\u529f\u80fd\u3002  - RESTful API \u8bbe\u8ba1 - MyBatis \u6570\u636e\u5e93\u6620\u5c04 - \u524d\u540e\u7aef\u5206\u79bb\u67b6\u6784     ### \u2600\ufe0f \u5929\u6c14\u9884\u62a5\u5e94\u7528\uff08Vue\uff09  **\u6280\u672f\u6808**\uff1aVue 3 + Vite + API \u8c03\u7528  \u8c03\u7528\u7b2c\u4e09\u65b9\u5929\u6c14 API\uff0c\u5c55\u793a\u5b9e\u65f6\u5929\u6c14\u3001\u672a\u6765 7 \u5929\u9884\u62a5\u3001\u57ce\u5e02\u641c\u7d22\u7b49\u529f\u80fd\u3002  - Vue 3 Composition API - Axios \u5f02\u6b65\u8bf7\u6c42 - \u54cd\u5e94\u5f0f\u5e03\u5c40\u9002\u914d     ### \ud83c\udfae Unity 3D \u5c0f\u7403\u95ef\u5173  **\u6280\u672f\u6808**\uff1aUnity + C#  \u4e00\u4e2a\u7b80\u5355\u7684 3D \u5e73\u53f0\u8df3\u8dc3\u6e38\u620f\uff0c\u73a9\u5bb6\u63a7\u5236\u5c0f\u7403\u901a\u8fc7\u969c\u788d\u5230\u8fbe\u7ec8\u70b9\u3002  - \u7269\u7406\u5f15\u64ce\u5e94\u7528 - C# \u811a\u672c\u7f16\u5199 - UI \u754c\u9762\u8bbe\u8ba1"},{"location":"projects/#_5","title":"\ud83d\udd2e \u672a\u6765\u8ba1\u5212","text":"<ul> <li>\ud83d\udcd6 \u5f00\u53d1\u4e00\u4e2a\u5728\u7ebf\u7f16\u7a0b\u7ec3\u4e60\u5e73\u53f0\uff08\u4ea4\u4e92\u5f0f\u4ee3\u7801\u7f16\u8f91\u5668 + \u81ea\u52a8\u8bc4\u6d4b\uff09</li> <li>\ud83d\udcf9 \u5236\u4f5c\u7f16\u7a0b\u6559\u5b66\u89c6\u9891\u7cfb\u5217\uff08\u4ece\u96f6\u5230\u4e00\u5b66 Web \u5f00\u53d1\uff09</li> <li>\ud83d\udee0\ufe0f \u6784\u5efa\u4e00\u4e2a\u8f7b\u91cf\u7ea7 Vue UI \u7ec4\u4ef6\u5e93\uff08\u4ece\u8bbe\u8ba1\u5230\u4ee3\u7801\u7684\u5168\u6d41\u7a0b\uff09</li> </ul>   [\ud83d\udc19 \u67e5\u770b\u66f4\u591a\u4ee3\u7801 \u2192 GitHub](https://github.com/gxw072423){ .md-button .md-button--primary }"}]}